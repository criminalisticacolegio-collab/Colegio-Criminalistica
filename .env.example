# Sanity
SANITY_API_WRITE_TOKEN=tu_token_sanity_con_permisos_de_escritura
SANITY_WEBHOOK_SECRET=clave_secreta_para_webhooks_de_sanity

# Email (Nodemailer + Gmail)
GMAIL_USER=criminalisticacolegio@gmail.com
GMAIL_APP_PASSWORD=tu_contrasena_de_aplicacion_gmail

# Firebase Admin SDK (JSON completo en una línea)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Admin Secret — protege endpoints internos (/api/sincronizar-padron, /api/otorgar-matricula, etc.)
# Usar una cadena aleatoria larga. Ej: openssl rand -hex 32
ADMIN_SECRET=cadena_aleatoria_muy_larga_y_secreta
# PUBLIC_ADMIN_SECRET debe ser igual a ADMIN_SECRET (lo usa el Sanity Studio desde el browser)
PUBLIC_ADMIN_SECRET=cadena_aleatoria_muy_larga_y_secreta

# Cron jobs — protege /api/cron-mora (llamado por Google Cloud Scheduler el 1° de cada mes)
CRON_SECRET=cpcc-cron-mora-2026

# MercadoPago
MP_ACCESS_TOKEN=tu_access_token_mp

# Sanity (público)
PUBLIC_SANITY_PROJECT_ID=8q7vz6co
PUBLIC_SANITY_DATASET=production
