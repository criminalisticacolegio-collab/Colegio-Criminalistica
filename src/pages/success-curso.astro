---
import MainLayout from '../layouts/MainLayout.astro';

// MercadoPago agrega estos parámetros al redirigir de vuelta
const params  = Astro.url.searchParams;
const status  = params.get('status') || params.get('collection_status') || '';
const aprobado = status === 'approved';
const pendiente = status === 'pending' || status === 'in_process';
---

<MainLayout title={aprobado ? 'Pago Confirmado' : 'Estado del Pago'} showBack={true}>
  <div class="container page-content">

    {aprobado ? (
      <!-- ══ PAGO APROBADO: auto-procesa desde sessionStorage ═══ -->
      <div class="result-card glass" id="result-card">
        <div class="result-icon" id="result-icon">⏳</div>
        <h1 id="result-title">Procesando tu inscripción…</h1>
        <p id="result-msg" class="result-msg">Estamos registrando tu acceso al campus. Un momento.</p>
        <div id="spinner" class="spinner"></div>
        <a href="/capacitacion" id="btn-volver" class="btn-back" style="display:none">← Volver a Formación Profesional</a>
      </div>

    ) : pendiente ? (
      <div class="result-card glass result-pending">
        <div class="result-icon">⏳</div>
        <h1>Pago en proceso</h1>
        <p class="result-msg">Tu pago está siendo verificado por MercadoPago.<br/>Te notificaremos por email cuando se confirme.</p>
        <a href="/capacitacion" class="btn-back">← Volver a Formación Profesional</a>
      </div>

    ) : (
      <div class="result-card glass result-error">
        <div class="result-icon">❌</div>
        <h1>Pago no completado</h1>
        <p class="result-msg">Hubo un inconveniente con el pago. Podés intentarlo nuevamente desde la página de Formación Profesional.</p>
        <a href="/capacitacion" class="btn-back">← Volver a Formación Profesional</a>
      </div>
    )}

  </div>
</MainLayout>

{aprobado && (
  <script>
    (async () => {
      const iconEl  = document.getElementById('result-icon')!;
      const titleEl = document.getElementById('result-title')!;
      const msgEl   = document.getElementById('result-msg')!;
      const spinner = document.getElementById('spinner')!;
      const btnVolver = document.getElementById('btn-volver') as HTMLAnchorElement;

      function showSuccess(msg: string) {
        spinner.style.display = 'none';
        iconEl.textContent   = '✅';
        titleEl.textContent  = '¡Pago confirmado!';
        msgEl.innerHTML      = msg;
        btnVolver.style.display = '';
      }

      function showError(msg: string) {
        spinner.style.display = 'none';
        iconEl.textContent   = '⚠️';
        titleEl.textContent  = 'Pago recibido';
        msgEl.innerHTML      = msg;
        btnVolver.style.display = '';
      }

      try {
        const stored = sessionStorage.getItem('mpCursoData');
        if (!stored) {
          showSuccess('Pago confirmado. <br/>Si no recibís el email de acceso en los próximos minutos, contactanos a <strong>criminalisticacolegio@gmail.com</strong>.');
          return;
        }

        const { cursoKey, email, nombreAlumno, ts } = JSON.parse(stored);

        // Ignorar datos con más de 2 horas (sesión expirada)
        if (Date.now() - ts > 2 * 60 * 60 * 1000) {
          sessionStorage.removeItem('mpCursoData');
          showSuccess('Pago confirmado. Revisá tu email — te enviamos el acceso al campus.');
          return;
        }

        const res = await fetch('/api/enviar-acceso-curso', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, cursoId: cursoKey, nombreAlumno }),
        });

        sessionStorage.removeItem('mpCursoData');

        if (res.ok) {
          showSuccess(`✅ Pago confirmado. <br/>Revisá tu email <strong>${email}</strong> — te enviamos el acceso al campus.`);
        } else {
          showError(`Pago registrado.<br/>Si no recibís el email en minutos, escribinos a <strong>criminalisticacolegio@gmail.com</strong> con el email <em>${email}</em>.`);
        }
      } catch {
        showError('Pago registrado. Revisá tu email o contactanos si no recibís el acceso en los próximos minutos.');
      }
    })();
  </script>
)}

<style>
  .page-content {
    padding: 6rem 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  .result-card {
    max-width: 560px;
    width: 100%;
    margin: 0 auto;
    text-align: center;
    padding: 3.5rem 2.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray-200);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .result-icon { font-size: 3.5rem; line-height: 1; }

  .result-card h1 {
    font-size: clamp(1.6rem, 3.5vw, 2rem);
    color: var(--primary);
    margin: 0;
  }

  .result-pending h1 { color: #d97706; }
  .result-error h1   { color: #dc2626; }

  .result-msg {
    color: var(--text-light);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--gray-200);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .btn-back {
    display: inline-flex;
    align-items: center;
    background: var(--primary);
    color: white;
    border: none;
    padding: 0.8rem 1.75rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: var(--transition);
    margin-top: 0.5rem;
  }
  .btn-back:hover { background: var(--primary-hover); transform: translateY(-2px); }
</style>
