---
export const prerender = false;

import { sanityClient } from 'sanity:client';

const data = await sanityClient.fetch(`*[_type == "mantenimientoConfig"][0]{
  emailAdministrador,
  notas,
  conceptos[]{ nombre, descripcion, proveedor, monto, activo }
}`).catch(() => null);

const conceptos = (data?.conceptos || []).filter(c => c.activo !== false);
const conceptosTodos = data?.conceptos || [];
const total = conceptos.reduce((s, c) => s + (c.monto || 0), 0);
const email = data?.emailAdministrador || '';

const url = new URL(Astro.request.url);
const status = url.searchParams.get('status');
const paymentId = url.searchParams.get('payment_id') || url.searchParams.get('collection_id') || '';
const isPaid = status === 'approved';
const isFailed = status === 'failure';

function formatARS(n) {
  return new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 2 }).format(n || 0);
}

const hoy = new Date().toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
const conceptosJSON = JSON.stringify(conceptos);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Mantenimiento Web — CPC CTM (Interno)</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; color: #1e293b; min-height: 100vh; }

    .admin-bar {
      background: #1e293b; color: white;
      padding: 0.75rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      font-size: 0.8rem;
    }
    .admin-bar span { opacity: 0.6; }
    .admin-badge {
      background: #ef4444; color: white;
      padding: 0.2rem 0.6rem; border-radius: 4px;
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .page { max-width: 820px; margin: 0 auto; padding: 2.5rem 1.5rem; }

    h1 { font-size: 1.75rem; font-weight: 700; color: #1e293b; margin-bottom: 0.4rem; }
    .subtitle { color: #64748b; font-size: 0.9rem; margin-bottom: 2.5rem; }

    /* Estado pago */
    .alert {
      padding: 1.25rem 1.5rem; border-radius: 12px;
      margin-bottom: 2rem; display: flex; align-items: flex-start; gap: 1rem;
    }
    .alert-success { background: #f0fdf4; border: 1px solid #86efac; }
    .alert-fail { background: #fff1f2; border: 1px solid #fca5a5; }
    .alert-icon { font-size: 1.5rem; flex-shrink: 0; }
    .alert-body strong { display: block; font-size: 1rem; font-weight: 700; margin-bottom: 0.3rem; }
    .alert-body p { font-size: 0.85rem; color: #475569; }
    .alert-success .alert-body strong { color: #15803d; }
    .alert-fail .alert-body strong { color: #dc2626; }

    /* Card */
    .card {
      background: white; border-radius: 16px;
      border: 1px solid #e2e8f0; margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .card-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid #f1f5f9;
      display: flex; align-items: center; justify-content: space-between;
    }
    .card-header h2 { font-size: 1rem; font-weight: 700; color: #1e293b; }
    .card-header span { font-size: 0.75rem; color: #94a3b8; }

    table { width: 100%; border-collapse: collapse; }
    th {
      text-align: left; padding: 0.85rem 1.5rem;
      font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
      color: #64748b; background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }
    td { padding: 1rem 1.5rem; font-size: 0.9rem; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr.inactive td { opacity: 0.4; text-decoration: line-through; }
    .td-nombre { font-weight: 600; }
    .td-desc { color: #64748b; font-size: 0.82rem; display: block; margin-top: 0.15rem; }
    .td-prov { color: #94a3b8; font-size: 0.78rem; }
    .td-monto { font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; }
    .td-badge {
      display: inline-block;
      padding: 0.1rem 0.5rem; border-radius: 4px; font-size: 0.7rem; font-weight: 700;
    }
    .badge-active { background: #dcfce7; color: #15803d; }
    .badge-off { background: #f1f5f9; color: #94a3b8; }

    .total-row { background: #1e293b; }
    .total-row td { color: white; font-weight: 700; font-size: 1rem; border-bottom: none; }
    .total-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.7; display: block; }

    .notas-card { padding: 1.25rem 1.5rem; }
    .notas-card h2 { font-size: 0.9rem; font-weight: 700; color: #64748b; margin-bottom: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em; }
    .notas-card p { font-size: 0.88rem; color: #475569; line-height: 1.6; white-space: pre-wrap; }

    .actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.75rem; border-radius: 10px;
      font-weight: 700; font-size: 0.9rem; cursor: pointer;
      border: none; transition: all 0.2s; text-decoration: none;
    }
    .btn-pay { background: #009ee3; color: white; }
    .btn-pay:hover { background: #0085c3; transform: translateY(-1px); }
    .btn-pay:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .btn-download { background: #1e293b; color: white; }
    .btn-download:hover { background: #334155; }
    .btn-sanity { background: white; color: #1e293b; border: 1px solid #e2e8f0; }
    .btn-sanity:hover { border-color: #94a3b8; }

    .empty { text-align: center; padding: 3rem; color: #94a3b8; }
    .empty span { font-size: 2.5rem; display: block; margin-bottom: 1rem; }

    .spin { animation: spin 1s linear infinite; display: inline-block; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 600px) {
      th:nth-child(3), td:nth-child(3) { display: none; }
    }
  </style>
</head>
<body>

  <div class="admin-bar">
    <div style="display:flex;align-items:center;gap:0.75rem">
      <span class="admin-badge">Interno</span>
      <span>Colegio de Profesionales en Ciencias Criminalísticas — Provincia de Catamarca</span>
    </div>
    <span>{hoy}</span>
  </div>

  <div class="page">
    <h1>🛠️ Mantenimiento del Sitio Web</h1>
    <p class="subtitle">Panel de administración interno — Desglose de costos y pago mensual</p>

    {isPaid && (
      <div class="alert alert-success">
        <div class="alert-icon">✅</div>
        <div class="alert-body">
          <strong>Pago acreditado correctamente</strong>
          <p>ID de transacción: <strong>{paymentId}</strong> · Podés descargar el comprobante abajo.</p>
        </div>
      </div>
    )}

    {isFailed && (
      <div class="alert alert-fail">
        <div class="alert-icon">❌</div>
        <div class="alert-body">
          <strong>El pago no pudo procesarse</strong>
          <p>Verificá los datos de tu tarjeta o intentá con otro medio de pago.</p>
        </div>
      </div>
    )}

    {conceptosTodos.length === 0 ? (
      <div class="card">
        <div class="empty">
          <span>🛠️</span>
          <p>No hay conceptos de mantenimiento cargados aún.</p>
          <p style="font-size:0.82rem;margin-top:0.5rem">Accedé a Sanity Studio → 🔒 Administración Interna → Mantenimiento del Sitio Web para agregar los conceptos.</p>
        </div>
      </div>
    ) : (
      <div class="card">
        <div class="card-header">
          <h2>Desglose de costos mensuales</h2>
          <span>{conceptos.length} concepto{conceptos.length !== 1 ? 's' : ''} activo{conceptos.length !== 1 ? 's' : ''}</span>
        </div>
        <table>
          <thead>
            <tr>
              <th>Concepto</th>
              <th>Proveedor</th>
              <th>Estado</th>
              <th style="text-align:right">Monto / mes</th>
            </tr>
          </thead>
          <tbody>
            {conceptosTodos.map((c: any) => (
              <tr class={c.activo === false ? 'inactive' : ''}>
                <td>
                  <span class="td-nombre">{c.nombre}</span>
                  {c.descripcion && <span class="td-desc">{c.descripcion}</span>}
                </td>
                <td class="td-prov">{c.proveedor || '—'}</td>
                <td>
                  <span class={`td-badge ${c.activo !== false ? 'badge-active' : 'badge-off'}`}>
                    {c.activo !== false ? 'Activo' : 'Inactivo'}
                  </span>
                </td>
                <td class="td-monto">{formatARS(c.monto)}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="total-row">
              <td colspan="3">
                <span class="total-label">Total mensual</span>
                {email && <span style="font-size:0.8rem;opacity:0.6;margin-left:1rem">{email}</span>}
              </td>
              <td class="td-monto" style="font-size:1.15rem">{formatARS(total)}</td>
            </tr>
          </tfoot>
        </table>
      </div>
    )}

    {data?.notas && (
      <div class="card">
        <div class="notas-card">
          <h2>Notas internas</h2>
          <p>{data.notas}</p>
        </div>
      </div>
    )}

    <div class="actions">
      {isPaid ? (
        <button id="btn-comprobante" class="btn btn-download">
          ⬇ Descargar Comprobante PDF
        </button>
      ) : (
        conceptos.length > 0 && (
          <button id="btn-pagar" class="btn btn-pay">
            <span id="pay-icon">💳</span>
            <span id="pay-text">Pagar con MercadoPago</span>
          </button>
        )
      )}
      <a href="/admin-colegio" class="btn btn-sanity">← Volver a Sanity Studio</a>
    </div>
  </div>

  <script define:vars={{ total, email, conceptosJSON, isPaid, paymentId, hoy }}>
    const conceptos = JSON.parse(conceptosJSON);

    // ── Botón pagar ──────────────────────────────────────
    const btnPagar = document.getElementById('btn-pagar');
    if (btnPagar) {
      btnPagar.addEventListener('click', async () => {
        const icon = document.getElementById('pay-icon');
        const text = document.getElementById('pay-text');
        btnPagar.disabled = true;
        icon.textContent = '⏳';
        text.textContent = 'Generando pago...';

        try {
          const res = await fetch('/api/pagar-mantenimiento', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ total, email }),
          });
          const data = await res.json();
          if (data.init_point) {
            window.location.href = data.init_point;
          } else {
            alert('Error al generar el pago: ' + (data.error || 'intentá de nuevo'));
            btnPagar.disabled = false;
            icon.textContent = '💳';
            text.textContent = 'Pagar con MercadoPago';
          }
        } catch {
          alert('Error de conexión. Verificá tu internet e intentá de nuevo.');
          btnPagar.disabled = false;
          icon.textContent = '💳';
          text.textContent = 'Pagar con MercadoPago';
        }
      });
    }

    // ── Botón comprobante PDF ─────────────────────────────
    const btnComprobante = document.getElementById('btn-comprobante');
    if (btnComprobante) {
      btnComprobante.addEventListener('click', async () => {
        btnComprobante.textContent = '⏳ Generando PDF...';
        btnComprobante.disabled = true;

        try {
          const { jsPDF } = await import('https://cdn.jsdelivr.net/npm/jspdf@2.5.1/+esm');
          const doc = new jsPDF({ unit: 'mm', format: 'a4' });
          const W = 210;
          const verde = [34, 197, 94];
          const oscuro = [30, 41, 59];
          const gris = [100, 116, 139];

          // Encabezado
          doc.setFillColor(...oscuro);
          doc.rect(0, 0, W, 38, 'F');
          doc.setFillColor(...verde);
          doc.rect(0, 38, W, 3, 'F');

          // Logo si existe
          try {
            const img = new Image();
            img.src = '/LOGO-CENTRAL.jpg';
            await new Promise(r => { img.onload = r; img.onerror = r; });
            if (img.naturalWidth) doc.addImage(img, 'JPEG', 10, 6, 22, 22);
          } catch {}

          doc.setTextColor(255, 255, 255);
          doc.setFontSize(13);
          doc.setFont('helvetica', 'bold');
          doc.text('COLEGIO DE PROFESIONALES EN CIENCIAS CRIMINALÍSTICAS', 38, 16);
          doc.setFontSize(9);
          doc.setFont('helvetica', 'normal');
          doc.text('Provincia de Catamarca', 38, 22);
          doc.setFontSize(8);
          doc.setTextColor(134, 239, 172);
          doc.text('ADMINISTRACIÓN INTERNA — DOCUMENTO NO PÚBLICO', 38, 28);

          // Título comprobante
          doc.setTextColor(...oscuro);
          doc.setFontSize(16);
          doc.setFont('helvetica', 'bold');
          doc.text('COMPROBANTE DE PAGO DE MANTENIMIENTO WEB', W / 2, 58, { align: 'center' });

          // Info pago
          doc.setFontSize(9);
          doc.setFont('helvetica', 'normal');
          doc.setTextColor(...gris);
          doc.text(`Fecha: ${hoy}`, 14, 70);
          if (paymentId) doc.text(`ID de transacción MercadoPago: ${paymentId}`, 14, 76);
          if (email) doc.text(`Email: ${email}`, 14, 82);

          // Línea
          doc.setDrawColor(...verde);
          doc.setLineWidth(0.4);
          doc.line(14, 88, W - 14, 88);

          // Tabla
          let y = 96;
          const col = [14, 80, 150, W - 14];

          // Cabecera tabla
          doc.setFillColor(248, 250, 252);
          doc.rect(14, y - 5, W - 28, 9, 'F');
          doc.setFont('helvetica', 'bold');
          doc.setFontSize(8);
          doc.setTextColor(...oscuro);
          doc.text('CONCEPTO', col[0], y);
          doc.text('PROVEEDOR', col[1], y);
          doc.text('MONTO (ARS)', col[3], y, { align: 'right' });
          y += 7;

          doc.setFont('helvetica', 'normal');
          conceptos.forEach(c => {
            doc.setTextColor(...oscuro);
            doc.text(c.nombre || '—', col[0], y, { maxWidth: 62 });
            doc.setTextColor(...gris);
            doc.text(c.proveedor || '—', col[1], y, { maxWidth: 62 });
            const monto = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 2 }).format(c.monto || 0);
            doc.setTextColor(...oscuro);
            doc.setFont('helvetica', 'bold');
            doc.text(monto, col[3], y, { align: 'right' });
            doc.setFont('helvetica', 'normal');
            y += 8;
            doc.setDrawColor(226, 232, 240);
            doc.setLineWidth(0.2);
            doc.line(14, y - 2, W - 14, y - 2);
          });

          // Total
          y += 4;
          doc.setFillColor(...oscuro);
          doc.rect(14, y - 6, W - 28, 12, 'F');
          doc.setFont('helvetica', 'bold');
          doc.setTextColor(255, 255, 255);
          doc.setFontSize(10);
          doc.text('TOTAL MENSUAL', col[0] + 2, y + 1);
          const totalFmt = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 2 }).format(total);
          doc.text(totalFmt, col[3], y + 1, { align: 'right' });

          // Sello pago
          y += 20;
          doc.setFillColor(240, 253, 244);
          doc.setDrawColor(134, 239, 172);
          doc.roundedRect(14, y, W - 28, 18, 3, 3, 'FD');
          doc.setTextColor(21, 128, 61);
          doc.setFontSize(9);
          doc.setFont('helvetica', 'bold');
          doc.text('✓ PAGO ACREDITADO — Procesado por MercadoPago', W / 2, y + 7, { align: 'center' });
          doc.setFont('helvetica', 'normal');
          doc.setTextColor(...gris);
          doc.text('Este documento es un comprobante de uso interno. No es una factura oficial.', W / 2, y + 13, { align: 'center' });

          // Pie
          doc.setFillColor(...oscuro);
          doc.rect(0, 279, W, 18, 'F');
          doc.setFillColor(...verde);
          doc.rect(0, 279, W, 1.5, 'F');
          doc.setTextColor(255, 255, 255);
          doc.setFontSize(7.5);
          doc.setFont('helvetica', 'normal');
          doc.text('Avenida América Latina 1672 — San Fernando del Valle de Catamarca', W / 2, 286, { align: 'center' });
          doc.text('criminalisticacolegio@gmail.com', W / 2, 292, { align: 'center' });

          doc.save(`comprobante-mantenimiento-${hoy.replace(/ /g, '-')}.pdf`);
        } catch (err) {
          console.error(err);
          alert('No se pudo generar el PDF. Intentá de nuevo.');
        } finally {
          btnComprobante.textContent = '⬇ Descargar Comprobante PDF';
          btnComprobante.disabled = false;
        }
      });
    }
  </script>
</body>
</html>
