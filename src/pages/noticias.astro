---
import MainLayout from '../layouts/MainLayout.astro';

const posts = [
	{ title: 'Nuevos Convenios con la UNCA', category: 'Institucional', date: '15 Abr 2026', image: 'https://images.unsplash.com/photo-1544650039-202c5d2592d3?auto=format&fit=crop&q=80&w=800', excerpt: 'Se firmó un acuerdo estratégico para capacitaciones conjuntas en medicina forense y balística avanzada.' },
	{ title: 'Asamblea Anual Ordinaria 2026', category: 'Circular', date: '10 Abr 2026', image: 'https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&q=80&w=800', excerpt: 'Convocatoria a todos los matriculados para la sesión de memoria y balance del ejercicio anterior.' },
	{ title: 'Apertura de Inscripción a Peritajes', category: 'Capacitación', date: '01 Abr 2026', image: 'https://images.unsplash.com/photo-1454162223060-7e3b1285257e?auto=format&fit=crop&q=80&w=800', excerpt: 'Abiertas las inscripciones para el listado oficial de peritos judiciales para el ciclo 2026-2027.' },
    { title: 'Innovación en Criminalística Digital', category: 'Tecnología', date: '25 Mar 2026', image: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&q=80&w=800', excerpt: 'Nuevos protocolos de recolección de evidencia en dispositivos móviles según estándares internacionales.' },
];
---

<MainLayout title="Noticias" showBack={true}>
	<div class="container page-content">
		<header class="section-header">
			<span class="sub-title">Actualidad y Novedades</span>
			<h1>Noticias del Colegio</h1>
			<p>El canal oficial de comunicación para el profesional y la comunidad científica.</p>
		</header>

		<div class="news-container">
			<div class="featured-news-grid">
				{posts.map(post => (
					<article class="post-card glass">
						<div class="post-header">
							<img src={post.image} alt={post.title} />
							<span class="category-tag">{post.category}</span>
						</div>
						<div class="post-body">
							<span class="date">{post.date}</span>
							<h2>{post.title}</h2>
							<p>{post.excerpt}</p>
							<div class="post-footer">
								<a href="#" class="btn-read">Leer más</a>
								<div class="share-btns">
									<span>🔗</span>
								</div>
							</div>
						</div>
					</article>
				))}
			</div>

			<div class="infinite-scroll-mock">
				<div class="loader">
					<div class="dot"></div>
					<div class="dot"></div>
					<div class="dot"></div>
				</div>
				<span>Cargando noticias anteriores...</span>
			</div>
		</div>
	</div>

	<style>
		.page-content { padding: 5rem 0; }
		
		.section-header { text-align: center; margin-bottom: 5rem; }
		.sub-title { color: var(--primary); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.9rem; display: block; margin-bottom: 1rem; }
		.section-header h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); margin-bottom: 1.5rem; color: var(--accent); }
		.section-header p { font-size: 1.25rem; color: var(--text-light); max-width: 800px; margin: 0 auto; }

		.featured-news-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap: 3rem; margin-bottom: 5rem; }
		
		.post-card { border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--gray-200); transition: var(--transition); display: flex; flex-direction: column; }
		.post-card:hover { transform: translateY(-10px); box-shadow: var(--shadow-lg); border-color: var(--primary); }
		
		.post-header { position: relative; height: 250px; }
		.post-header img { width: 100%; height: 100%; object-fit: cover; }
		.category-tag { position: absolute; top: 1.25rem; left: 1.25rem; background: var(--primary); color: white; padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; }

		.post-body { padding: 2.25rem; display: flex; flex-direction: column; flex: 1; }
		.date { font-size: 0.85rem; color: var(--primary); font-weight: 700; margin-bottom: 0.75rem; }
		.post-body h2 { font-size: 1.5rem; margin-bottom: 1rem; line-height: 1.3; }
		.post-body p { color: var(--text-light); line-height: 1.6; font-size: 1rem; margin-bottom: 2rem; }

		.post-footer { margin-top: auto; display: flex; justify-content: space-between; align-items: center; }
		.btn-read { color: var(--text-main); text-decoration: none; font-weight: 700; border-bottom: 2px solid var(--primary); padding-bottom: 2px; transition: var(--transition); }
		.btn-read:hover { color: var(--primary); letter-spacing: 0.5px; }

		/* Infinite Scroll Mock */
		.infinite-scroll-mock { text-align: center; color: var(--text-light); font-weight: 600; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
		.loader { display: flex; gap: 8px; margin-bottom: 0.5rem; }
		.loader .dot { width: 10px; height: 10px; background: var(--primary); border-radius: 50%; animation: loaderSpin 1.4s infinite; opacity: 0.6; }
		.loader .dot:nth-child(2) { animation-delay: 0.2s; }
		.loader .dot:nth-child(3) { animation-delay: 0.4s; }

		@keyframes loaderSpin {
			0%, 100% { transform: scale(1); opacity: 0.3; }
			50% { transform: scale(1.5); opacity: 1; }
		}

		@media (max-width: 768px) {
			.featured-news-grid { grid-template-columns: 1fr; }
		}
	</style>
</MainLayout>
