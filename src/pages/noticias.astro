---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const data = await sanityClient.fetch(`*[_type == "noticiasConfig"][0]{
  textoPrincipal,
  "novedades": novedades[publicado != false] | order(fecha desc) {
    titulo,
    bajada,
    fecha,
    categoria,
    link,
    "imagen": imagen.asset->url,
    "archivo": archivo.asset->url
  }
}`);

const novedades: any[] = data?.novedades || [];

function formatFecha(dateStr: string) {
  if (!dateStr) return '';
  const [y, m, d] = dateStr.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const catColors: Record<string, string> = {
  Institucional: '#16a34a',
  Resolucion:    '#7c3aed',
  Capacitacion:  '#0891b2',
  Convocatoria:  '#d97706',
  General:       '#4b5563',
};
function cc(cat: string) { return catColors[cat] || '#4b5563'; }
---

<MainLayout title="Noticias y Novedades">

  {novedades.length === 0 ? (

    <div class="container" style="padding: 7rem 0; text-align: center;">
      <div class="empty-state">
        <div class="empty-ico">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="52" height="52"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v4"/><path d="M2 13h10M9 18H2M2 9h6"/></svg>
        </div>
        <h2>Sin novedades publicadas</h2>
        <p>{data?.textoPrincipal || 'Las noticias aparecerán aquí cuando sean publicadas desde el panel de administración.'}</p>
      </div>
    </div>

  ) : (

    <section class="grid-section">
      <div class="container">

        <header class="grid-header">
          <div>
            <h1>Noticias y Comunicados</h1>
            {data?.textoPrincipal && <p class="grid-intro">{data.textoPrincipal}</p>}
          </div>
          <span class="grid-count">{novedades.length} {novedades.length === 1 ? 'novedad' : 'novedades'}</span>
        </header>

        <div class="news-grid">
          {novedades.map((post: any) => (
            <article class="nc">

              <div class="nc-img-wrap">
                {post.imagen
                  ? <img src={post.imagen} alt={post.titulo} class="nc-img" loading="lazy" />
                  : <div class="nc-img-fallback" style={`background: linear-gradient(135deg, ${cc(post.categoria)}28 0%, ${cc(post.categoria)}50 100%)`}>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="34" height="34" style={`color: ${cc(post.categoria)}`}><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v4"/><path d="M2 13h10M9 18H2M2 9h6"/></svg>
                    </div>
                }
                {post.categoria && (
                  <span class="nc-badge" style={`background: ${cc(post.categoria)}`}>{post.categoria}</span>
                )}
              </div>

              <div class="nc-body">
                <time class="nc-date" datetime={post.fecha}>{formatFecha(post.fecha)}</time>
                <h3 class="nc-title">{post.titulo}</h3>
                {post.bajada && <p class="nc-excerpt">{post.bajada}</p>}
                <footer class="nc-footer">
                  {post.link
                    ? <a href={post.link} target="_blank" rel="noopener noreferrer" class="nc-btn">
                        Leer más
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                      </a>
                    : post.archivo
                      ? <a href={post.archivo} target="_blank" rel="noopener noreferrer" class="nc-btn nc-btn-pdf" download>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                          Descargar PDF
                        </a>
                      : null
                  }
                </footer>
              </div>

            </article>
          ))}
        </div>

      </div>
    </section>

  )}


  <style>
    /* ══════════════════════════════════════════
       GRILLA DE TARJETAS
    ══════════════════════════════════════════ */
    .grid-section {
      padding: 4rem 0 6rem;
    }

    .grid-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 2.25rem;
      padding-bottom: 1.2rem;
      border-bottom: 2px solid var(--gray-200, #e5e7eb);
    }

    .grid-header h1 {
      font-size: clamp(1.4rem, 2.8vw, 1.9rem);
      font-weight: 700;
      color: var(--accent, #1a2e1d);
      margin-bottom: 0.3rem;
    }

    .grid-intro {
      font-size: 0.92rem;
      color: var(--text-light, #6b7280);
      line-height: 1.5;
      max-width: 560px;
    }

    .grid-count {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-light, #6b7280);
      background: var(--gray-100, #f3f4f6);
      padding: 0.22rem 0.7rem;
      border-radius: 20px;
      white-space: nowrap;
      flex-shrink: 0;
      margin-top: 0.35rem;
    }

    .news-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }

    /* ── Card ── */
    .nc {
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--gray-200, #e5e7eb);
      display: flex;
      flex-direction: column;
      transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
    }
    .nc:hover {
      transform: translateY(-5px);
      box-shadow: 0 14px 40px rgba(0,0,0,0.10);
      border-color: var(--primary, #1a5c2a);
    }

    .nc-img-wrap {
      position: relative;
      height: 200px;
      overflow: hidden;
      flex-shrink: 0;
    }

    .nc-img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center;
      transition: transform 0.38s ease;
    }
    .nc:hover .nc-img { transform: scale(1.05); }

    .nc-img-fallback {
      width: 100%; height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nc-badge {
      position: absolute;
      top: 0.75rem; left: 0.75rem;
      color: #fff;
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.24rem 0.68rem;
      border-radius: 20px;
    }

    .nc-body {
      padding: 1.4rem 1.5rem 1.5rem;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .nc-date {
      font-size: 0.76rem;
      font-weight: 700;
      color: var(--primary, #1a5c2a);
      margin-bottom: 0.45rem;
      display: block;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .nc-title {
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.35;
      color: var(--accent, #1a2e1d);
      margin-bottom: 0.65rem;
    }

    .nc-excerpt {
      font-size: 0.87rem;
      line-height: 1.58;
      color: var(--text-light, #6b7280);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      flex: 1;
      margin-bottom: 1.2rem;
    }

    .nc-footer { margin-top: auto; }

    .nc-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.38rem;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--primary, #1a5c2a);
      text-decoration: none;
      border-bottom: 2px solid transparent;
      padding-bottom: 1px;
      transition: border-color 0.18s ease, gap 0.18s ease;
    }
    .nc-btn:hover {
      border-color: var(--primary, #1a5c2a);
      gap: 0.6rem;
    }

    .nc-btn-pdf { color: #7c3aed; }
    .nc-btn-pdf:hover { border-color: #7c3aed; }


    /* ══════════════════════════════════════════
       EMPTY STATE
    ══════════════════════════════════════════ */
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.25rem;
    }
    .empty-ico {
      width: 84px; height: 84px;
      background: var(--primary-soft, #e8f4ed);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary, #1a5c2a);
    }
    .empty-state h2 { font-size: 1.5rem; color: var(--accent, #1a2e1d); font-weight: 700; }
    .empty-state p  { color: var(--text-light, #6b7280); max-width: 480px; line-height: 1.6; }


    /* ══════════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════════ */
    @media (max-width: 1100px) {
      .news-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .news-grid { grid-template-columns: 1fr; gap: 1.25rem; }
      .grid-section { padding: 3rem 0 4rem; }
      .nc-img-wrap { height: 180px; }
      .grid-header { flex-direction: column; }
    }
  </style>

</MainLayout>
