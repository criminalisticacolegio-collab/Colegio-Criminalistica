---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const [matriculadosActivos, cursosArray] = await Promise.all([
  sanityClient.fetch(`count(*[_type == "matriculado" && estado == "Activo"])`).catch(() => 0),
  sanityClient.fetch(`*[_type == "capacitacionConfig"][0].cursos[activo != false]`).catch(() => []),
]);
const capacitacionesCount = cursosArray?.length || 0;

const data = await sanityClient.fetch(`*[_type == "gestionConfig"][0]{
  textoInstitucional,
  resultadoEjercicio,
  anioEjercicio,
  descripcionEjercicio,
  hitosGestion,
  "memorias":     memorias[]{ titulo, anio, descripcion, "archivo": archivo.asset->url } | order(anio desc),
  "balances":     balances[]{ titulo, periodo, descripcion, "archivo": archivo.asset->url },
  "proyectos":    proyectos[]{ titulo, descripcion, "archivo": archivo.asset->url },
  "resoluciones": resoluciones[]{ numero, fecha, descripcion, "archivo": archivo.asset->url } | order(fecha desc)
}`).catch(() => null);

const memorias          = data?.memorias     || [];
const balances          = data?.balances     || [];
const proyectos         = data?.proyectos    || [];
const resoluciones      = data?.resoluciones || [];
const resultadoEjercicio: number = data?.resultadoEjercicio || 0;
const anioEjercicio: string      = data?.anioEjercicio || '2024';
const descripcionEjercicio: string = data?.descripcionEjercicio || '';
const hayDatos = memorias.length > 0 || balances.length > 0 || resoluciones.length > 0;

const hitosDefault = [
  { mes: 'Jun', anio: '2024', icono: '🏛️', titulo: 'Constitución formal del Colegio',    descripcion: 'Primera Comisión Directiva electa formalmente' },
  { mes: 'Oct', anio: '2024', icono: '⚖️', titulo: 'Convenio Poder Judicial',             descripcion: 'Acuerdo marco para provisión oficial de lista de peritos' },
  { mes: 'Feb', anio: '2025', icono: '🌐', titulo: 'Plataforma web oficial',              descripcion: 'Lanzamiento del sitio institucional con padrón dinámico' },
  { mes: 'Abr', anio: '2025', icono: '📚', titulo: 'Biblioteca Digital',                  descripcion: 'Más de 30 recursos descargables disponibles' },
  { mes: 'May', anio: '2025', icono: '🎓', titulo: 'Campus Virtual',                      descripcion: 'Primer curso gratuito publicado para matriculados' },
  { mes: 'Ago', anio: '2025', icono: '💼', titulo: 'Bolsa de Trabajo',                    descripcion: 'Sistema de oferentes y demandantes activo' },
];
const hitos = (data?.hitosGestion?.length > 0) ? data.hitosGestion : hitosDefault;

function formatFecha(dateStr: string) {
  if (!dateStr) return '';
  const [y, m, d] = dateStr.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const gestionPayload  = JSON.stringify({ memorias, balances, resoluciones });
const metricasPayload = JSON.stringify({ matriculadosActivos, capacitacionesCount, resultadoEjercicio });
---

<MainLayout title="Gestión y Transparencia" showBack={true}>

  <!-- ══ SECCIÓN 1: HERO CON MÉTRICAS ══ -->
  <section class="hero-gestion">
    <div class="container">
      <div class="hero-text" style="text-align:center">
        <span class="hero-period">Período 2024–2026</span>
        <h1>Gestión y Transparencia</h1>
        <p class="hero-sub">Lista Renovación y Transparencia Profesional</p>
      </div>
      <div class="metricas-row">
        <div class="mc-card">
          <span class="mc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <span class="mc-num" data-target={matriculadosActivos} data-format="num">0</span>
          <span class="mc-label">Matriculados Activos</span>
        </div>
        <div class="mc-card">
          <span class="mc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </span>
          <span class="mc-num" data-target={capacitacionesCount} data-format="num">0</span>
          <span class="mc-label">Capacitaciones Realizadas</span>
        </div>
        <div class="mc-card">
          <span class="mc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
          </span>
          <span class="mc-num" data-target={resultadoEjercicio} data-format="ars">$ 0</span>
          <span class="mc-label">Resultado Ejercicio</span>
          {descripcionEjercicio && <span class="mc-sublabel">{descripcionEjercicio}</span>}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ SECCIÓN 2: LÍNEA DE TIEMPO ══ -->
  <section class="timeline-section">
    <div class="container">
      <h2 class="sec-title">Logros de la Gestión</h2>
      <div class="timeline">
        {hitos.map((h: any, i: number) => (
          <div class="tl-item" style={`--i:${i}`}>
            <div class="tl-top">
              <span class="tl-ico">{h.icono}</span>
              <span class="tl-date">{h.mes} {h.anio}</span>
            </div>
            <div class="tl-dot"></div>
            <div class="tl-btm">
              <h4 class="tl-titulo">{h.titulo}</h4>
              <p class="tl-desc">{h.descripcion}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ SECCIÓN 3: DOS COLUMNAS ══ -->
  <section class="dos-col-section">
    <div class="container">
      <div class="dos-col-layout">

        <!-- COLUMNA IZQUIERDA: EVALUADOR IA (código original sin modificar) -->
        <aside class="col-evaluador">
          <div class="dashboard-card glass-dark">
            <div class="db-header">
              <div class="ai-orb"></div>
              <div class="db-title">
                <h3>Evaluador de Gestión</h3>
                <span>Índices Institucionales</span>
              </div>
            </div>
            <div class="metrics-grid" id="metrics-grid">
              <div class="metric-item" data-metric="transparencia">
                <span class="m-label">Transparencia Financiera</span>
                <div class="m-bar"><div class="m-fill" style="width:0%"></div></div>
                <span class="m-value">—</span>
              </div>
              <div class="metric-item" data-metric="eficiencia">
                <span class="m-label">Eficiencia Operativa</span>
                <div class="m-bar"><div class="m-fill" style="width:0%"></div></div>
                <span class="m-value">—</span>
              </div>
              <div class="metric-item" data-metric="crecimiento">
                <span class="m-label">Crecimiento Matricular</span>
                <div class="m-bar"><div class="m-fill" style="width:0%"></div></div>
                <span class="m-value">—</span>
              </div>
              <div class="metric-item" data-metric="respuesta">
                <span class="m-label">Respuesta al Asociado</span>
                <div class="m-bar"><div class="m-fill" style="width:0%"></div></div>
                <span class="m-value">—</span>
              </div>
              <div class="metric-item" data-metric="calificacion">
                <span class="m-label">Calificación General</span>
                <div class="m-bar"><div class="m-fill" style="width:0%"></div></div>
                <span class="m-value">—</span>
              </div>
            </div>
            <div class="stats-row">
              <div class="stat-item">
                <span class="stat-num">{memorias.length}</span>
                <span class="stat-label">Memorias</span>
              </div>
              <div class="stat-item">
                <span class="stat-num">{balances.length}</span>
                <span class="stat-label">Balances</span>
              </div>
              <div class="stat-item">
                <span class="stat-num">{resoluciones.length}</span>
                <span class="stat-label">Resoluciones</span>
              </div>
            </div>
            {hayDatos && (
              <button id="btn-evaluar" class="btn-evaluar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                Evaluar gestión con IA
              </button>
            )}
          </div>
          <div id="eval-result" class="eval-result hidden">
            <div class="eval-header">
              <span>Evaluación IA</span>
              <button id="eval-close">✕</button>
            </div>
            <div id="eval-body" class="eval-body"></div>
          </div>
        </aside>

        <!-- COLUMNA DERECHA: DOCUMENTOS EN ACORDEÓN -->
        <div class="col-docs">
          <h2 class="col-docs-title">Documentación Institucional</h2>

          <!-- Memorias -->
          <div class="acordeon-item">
            <button class="acordeon-btn" data-target="ac-memorias">
              <span class="ac-icon">🗂️</span>
              <span class="ac-lbl">Memorias de Gestión</span>
              {memorias.length > 0 && <span class="ac-badge">{memorias.length}</span>}
              <svg class="ac-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="acordeon-body hidden" id="ac-memorias">
              {memorias.length === 0
                ? <p class="ac-empty">Sin documentos cargados aún.</p>
                : memorias.map((m: any) => (
                    <div class="file-item">
                      <div class="file-row">
                        <span class="pdf-ico">📄</span>
                        <div class="file-info">
                          <span class="file-name">{m.titulo}{m.anio ? ` (${m.anio})` : ''}</span>
                          {m.descripcion && <span class="file-desc">{m.descripcion}</span>}
                        </div>
                        <div class="file-actions">
                          {m.archivo
                            ? <a href={m.archivo} target="_blank" rel="noopener" class="btn-dl">Descargar</a>
                            : <span class="no-archivo">—</span>}
                        </div>
                      </div>
                    </div>
                  ))
              }
            </div>
          </div>

          <!-- Balances -->
          <div class="acordeon-item">
            <button class="acordeon-btn" data-target="ac-balances">
              <span class="ac-icon">📊</span>
              <span class="ac-lbl">Balances</span>
              {balances.length > 0 && <span class="ac-badge">{balances.length}</span>}
              <svg class="ac-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="acordeon-body hidden" id="ac-balances">
              {balances.length === 0
                ? <p class="ac-empty">Sin documentos cargados aún.</p>
                : balances.map((b: any) => (
                    <div class="file-item">
                      <div class="file-row">
                        <span class="pdf-ico">📄</span>
                        <div class="file-info">
                          <span class="file-name">{b.titulo}{b.periodo ? ` · ${b.periodo}` : ''}</span>
                          {b.descripcion && <span class="file-desc">{b.descripcion}</span>}
                        </div>
                        <div class="file-actions">
                          {b.archivo
                            ? <a href={b.archivo} target="_blank" rel="noopener" class="btn-dl">Descargar</a>
                            : <span class="no-archivo">—</span>}
                        </div>
                      </div>
                    </div>
                  ))
              }
            </div>
          </div>

          <!-- Proyectos -->
          <div class="acordeon-item">
            <button class="acordeon-btn" data-target="ac-proyectos">
              <span class="ac-icon">🚀</span>
              <span class="ac-lbl">Proyectos e Iniciativas</span>
              {proyectos.length > 0 && <span class="ac-badge">{proyectos.length}</span>}
              <svg class="ac-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="acordeon-body hidden" id="ac-proyectos">
              {proyectos.length === 0
                ? <p class="ac-empty">Sin documentos cargados aún.</p>
                : proyectos.map((p: any) => (
                    <div class="file-item">
                      <div class="file-row">
                        <span class="pdf-ico">📄</span>
                        <div class="file-info">
                          <span class="file-name">{p.titulo}</span>
                          {p.descripcion && <span class="file-desc">{p.descripcion}</span>}
                        </div>
                        <div class="file-actions">
                          {p.archivo
                            ? <a href={p.archivo} target="_blank" rel="noopener" class="btn-dl">Descargar</a>
                            : <span class="no-archivo">—</span>}
                        </div>
                      </div>
                    </div>
                  ))
              }
            </div>
          </div>

          <!-- Resoluciones -->
          <div class="acordeon-item">
            <button class="acordeon-btn" data-target="ac-resoluciones">
              <span class="ac-icon">🏛️</span>
              <span class="ac-lbl">Resoluciones</span>
              {resoluciones.length > 0 && <span class="ac-badge">{resoluciones.length}</span>}
              <svg class="ac-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="acordeon-body hidden" id="ac-resoluciones">
              {resoluciones.length === 0
                ? <p class="ac-empty">Sin resoluciones cargadas aún.</p>
                : resoluciones.map((r: any) => (
                    <div class="file-item">
                      <div class="file-row">
                        <span class="pdf-ico">📄</span>
                        <div class="file-info">
                          <span class="file-name">
                            {r.numero ? `Res. ${r.numero}` : 'Resolución'}
                            {r.fecha ? ` · ${formatFecha(r.fecha)}` : ''}
                          </span>
                          {r.descripcion && <span class="file-desc">{r.descripcion}</span>}
                        </div>
                        <div class="file-actions">
                          {r.archivo
                            ? <a href={r.archivo} target="_blank" rel="noopener" class="btn-dl">Descargar</a>
                            : <span class="no-archivo">—</span>}
                        </div>
                      </div>
                    </div>
                  ))
              }
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ SECCIÓN 4: FOOTER ══ -->
  <section class="gestion-footer">
    <div class="container footer-inner">
      <p class="footer-text">
        Toda la documentación institucional está disponible para consulta pública en cumplimiento
        del principio de transparencia — Ley N° 5.595/19
      </p>
      <button class="btn-rendicion" id="btn-rendicion">
        📥 Descargar rendición completa
      </button>
    </div>
  </section>

  <style>
    /* ── Hero ──────────────────────────────────────────────── */
    .hero-gestion {
      background: #f8f9fa;
      padding: 5rem 0 4rem;
    }
    .hero-text { margin-bottom: 3rem; }
    .hero-period {
      display: block;
      font-size: 0.78rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--primary);
      margin-bottom: 0.75rem;
    }
    .hero-gestion h1 {
      font-size: clamp(1.9rem, 4.5vw, 2.8rem);
      color: var(--accent);
      margin: 0 0 0.5rem;
    }
    .hero-sub { font-size: 1rem; color: var(--text-light); margin: 0; }

    .metricas-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .mc-card {
      background: var(--primary);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 16px;
      padding: 1.75rem 1.25rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .mc-icon { display: flex; align-items: center; justify-content: center; }
    .mc-icon svg { width: 2.5rem; height: 2.5rem; stroke: rgba(255,255,255,0.92); }
    .mc-num {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 800;
      color: white;
      line-height: 1;
    }
    .mc-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.7);
      font-weight: 700;
    }
    .mc-sublabel {
      font-size: 0.68rem;
      color: rgba(255,255,255,0.55);
      font-style: italic;
      margin-top: -0.25rem;
    }

    /* ── Timeline ──────────────────────────────────────────── */
    .timeline-section { padding: 5rem 0; background: #f8f9fa; }
    .sec-title {
      text-align: center;
      font-size: clamp(1.4rem, 2.5vw, 1.9rem);
      color: var(--accent);
      margin-bottom: 3.5rem;
    }

    .timeline {
      display: flex;
      position: relative;
      gap: 0;
    }
    .timeline::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--gray-200);
      transform: translateY(-50%);
      z-index: 0;
    }
    .tl-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity 0.5s ease calc(var(--i, 0) * 0.1s),
        transform 0.5s ease calc(var(--i, 0) * 0.1s);
    }
    .tl-item.visible { opacity: 1; transform: translateY(0); }
    .tl-top {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      gap: 0.3rem;
      padding: 0 0.5rem 1.25rem;
    }
    .tl-ico { font-size: 1.4rem; line-height: 1; }
    .tl-date {
      font-size: 0.67rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--primary);
    }
    .tl-dot {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--primary);
      border: 3px solid white;
      box-shadow: 0 0 0 2px var(--primary);
      position: relative;
      z-index: 1;
      flex-shrink: 0;
    }
    .tl-btm {
      flex: 1;
      padding: 1.25rem 0.5rem 0;
    }
    .tl-titulo {
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--accent);
      margin: 0 0 0.3rem;
      line-height: 1.3;
    }
    .tl-desc {
      font-size: 0.68rem;
      color: var(--text-light);
      line-height: 1.4;
      margin: 0;
    }

    /* ── Dos columnas ──────────────────────────────────────── */
    .dos-col-section { padding: 5rem 0; }
    .dos-col-layout {
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 3rem;
      align-items: start;
    }

    /* Evaluador IA — estilos originales conservados */
    .col-evaluador { position: sticky; top: 100px; }
    .glass-dark {
      background: var(--gray-900);
      color: white;
      padding: 2.5rem;
      border-radius: var(--radius-lg);
      border: 1px solid rgba(255,255,255,0.1);
    }
    .db-header { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 2.5rem; }
    .ai-orb {
      width: 36px; height: 36px;
      background: conic-gradient(from 180deg at 50% 50%, var(--primary) 0deg, #50C878 360deg);
      border-radius: 50%;
      animation: spin 4s linear infinite;
      box-shadow: 0 0 12px var(--primary);
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .db-title h3 { color: white; font-size: 1.1rem; margin: 0; }
    .db-title span { font-size: 0.7rem; text-transform: uppercase; color: var(--primary); font-weight: 800; }

    .metrics-grid { display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem; }
    .metric-item { display: flex; flex-direction: column; gap: 0.4rem; }
    .m-label { font-size: 0.75rem; color: rgba(255,255,255,0.6); }
    .m-bar { height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; }
    .m-fill { height: 100%; background: var(--primary); border-radius: 3px; transition: width 1.2s cubic-bezier(.4,0,.2,1); }
    .m-fill.green  { background: #22c55e; }
    .m-fill.yellow { background: #f59e0b; }
    .m-fill.red    { background: #ef4444; }
    .m-value { font-size: 0.95rem; font-weight: 700; color: white; align-self: flex-end; margin-top: -6px; }

    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; }
    .stat-item { text-align: center; }
    .stat-num { display: block; font-size: 2rem; font-weight: 800; color: var(--primary); }
    .stat-label { font-size: 0.7rem; text-transform: uppercase; color: rgba(255,255,255,0.5); font-weight: 700; }

    .btn-evaluar {
      margin-top: 1.5rem; width: 100%;
      display: flex; align-items: center; justify-content: center; gap: 0.5rem;
      padding: 0.85rem; background: var(--primary); color: white;
      border: none; border-radius: 10px; font-weight: 700; font-size: 0.9rem;
      cursor: pointer; transition: var(--transition); font-family: inherit;
    }
    .btn-evaluar:hover:not(:disabled) { background: var(--primary-hover); transform: translateY(-1px); }
    .btn-evaluar:disabled { opacity: 0.6; cursor: not-allowed; }

    .eval-result {
      margin-top: 1.5rem; border-radius: var(--radius-md);
      border: 1px solid rgba(255,255,255,0.15); overflow: hidden;
      background: var(--gray-900);
    }
    .eval-header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.75rem 1rem; background: var(--primary);
      font-size: 0.8rem; font-weight: 800; text-transform: uppercase; color: white;
    }
    .eval-header button { background: rgba(255,255,255,0.2); border: none; color: white; width: 22px; height: 22px; border-radius: 50%; cursor: pointer; font-size: 0.8rem; }
    .eval-body { padding: 1rem; background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.85); font-size: 0.85rem; line-height: 1.65; white-space: pre-wrap; max-height: 350px; overflow-y: auto; }

    /* Columna docs */
    .col-docs { display: flex; flex-direction: column; gap: 0.75rem; }
    .col-docs-title { font-size: 1.2rem; color: var(--accent); margin: 0 0 0.5rem; }

    /* Acordeón */
    .acordeon-item { border: 1px solid var(--gray-200); border-radius: var(--radius-md); overflow: hidden; }
    .acordeon-btn {
      width: 100%;
      display: flex; align-items: center; gap: 0.7rem;
      padding: 1rem 1.25rem;
      background: var(--white); border: none;
      font-family: inherit; font-size: 0.9rem; font-weight: 700;
      color: var(--accent); cursor: pointer; text-align: left;
      transition: background 0.15s;
    }
    .acordeon-btn:hover { background: var(--primary-soft); }
    .acordeon-btn.open  { background: var(--primary-soft); border-bottom: 1px solid var(--gray-200); }
    .ac-icon { font-size: 1.1rem; flex-shrink: 0; }
    .ac-lbl  { flex: 1; }
    .ac-badge {
      font-size: 0.7rem; font-weight: 800;
      background: var(--primary); color: white;
      border-radius: 999px; padding: 0.1rem 0.55rem;
      flex-shrink: 0;
    }
    .ac-arrow { color: var(--text-light); transition: transform 0.2s ease; flex-shrink: 0; }
    .acordeon-btn.open .ac-arrow { transform: rotate(180deg); }

    .acordeon-body {
      display: flex; flex-direction: column; gap: 0.65rem;
      padding: 1rem; background: var(--gray-50);
    }
    .ac-empty { font-size: 0.85rem; color: var(--text-light); text-align: center; padding: 0.5rem 0; margin: 0; }

    /* Doc cards */
    .file-item { display: flex; flex-direction: column; }
    .file-row {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.75rem 1rem;
      background: white; border: 1px solid var(--gray-200); border-radius: 8px;
    }
    .file-row:hover { border-color: var(--primary); }
    .pdf-ico { font-size: 1.4rem; flex-shrink: 0; }
    .file-info { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
    .file-name { font-size: 0.86rem; font-weight: 600; color: var(--text-main); }
    .file-desc { font-size: 0.76rem; color: var(--text-light); }
    .file-actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
    .btn-dl {
      font-size: 0.76rem; font-weight: 700;
      padding: 0.35rem 0.75rem; background: var(--primary); color: white;
      border-radius: 6px; text-decoration: none; transition: var(--transition); white-space: nowrap;
    }
    .btn-dl:hover { background: var(--primary-hover); }
    .no-archivo { color: var(--gray-300); font-size: 0.85rem; }
    .btn-analizar-doc {
      font-size: 1rem; background: none; border: 1px solid var(--gray-300);
      border-radius: 6px; padding: 0.2rem 0.4rem; cursor: pointer;
      transition: var(--transition); line-height: 1;
    }
    .btn-analizar-doc:hover { background: var(--primary-soft); border-color: var(--primary); }
    .btn-analizar-doc:disabled { opacity: 0.5; cursor: not-allowed; }
    .doc-result {
      margin: 0.3rem 0 0; padding: 0.85rem 1rem;
      background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px;
      font-size: 0.82rem; color: var(--text-main); line-height: 1.6; white-space: pre-wrap;
    }
    .doc-result.loading { background: var(--primary-soft); color: var(--primary); border-color: var(--primary); }

    /* ── Footer ────────────────────────────────────────────── */
    .gestion-footer { background: #1a5c2a; padding: 4rem 0; }
    .footer-inner { display: flex; flex-direction: column; align-items: center; gap: 2rem; text-align: center; }
    .footer-text { font-size: 1rem; color: rgba(255,255,255,0.82); max-width: 660px; line-height: 1.75; margin: 0; }
    .btn-rendicion {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.9rem 2rem; background: white; color: #1a5c2a;
      border: none; border-radius: 10px; font-weight: 800; font-size: 0.95rem;
      cursor: pointer; transition: var(--transition); font-family: inherit;
    }
    .btn-rendicion:hover { opacity: 0.92; transform: translateY(-2px); }

    .hidden { display: none !important; }

    /* ── Responsive ────────────────────────────────────────── */
    @media (max-width: 1024px) {
      .dos-col-layout { grid-template-columns: 1fr; }
      .col-evaluador { position: static; }
    }
    @media (max-width: 768px) {
      .metricas-row { grid-template-columns: 1fr; }

      /* Timeline vertical en mobile */
      .timeline {
        display: flex;
        flex-direction: column;
        gap: 0;
        padding-left: 2.5rem;
      }
      .timeline::before {
        top: 0; bottom: 0;
        left: 0.45rem;
        right: auto;
        width: 2px; height: 100%;
        transform: none;
      }
      .tl-item {
        flex-direction: row;
        text-align: left;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem 0;
        position: relative;
      }
      .tl-top {
        flex-direction: row; flex: 0 0 auto;
        padding: 0; justify-content: flex-start;
        align-items: center; gap: 0.4rem;
        min-width: 70px;
      }
      .tl-dot {
        position: absolute;
        left: -2.25rem;
        top: 1.2rem;
      }
      .tl-btm { padding-top: 0; flex: 1; }
    }
    @media (max-width: 480px) {
      .hero-gestion { padding: 4rem 0 3rem; }
      .mc-card { padding: 1.25rem 1rem; }
    }
  </style>

  <script define:vars={{ gestionPayload, metricasPayload }}>
    /* ── Métricas animadas ─────────────────────────────────── */
    var metricas;
    try { metricas = JSON.parse(metricasPayload); } catch(e) { metricas = {}; }

    function countUp(el, target, format) {
      if (!el || !target) return;
      var duration = 1800, fps = 60;
      var steps = Math.ceil(duration / (1000 / fps));
      var step = 0;
      var timer = setInterval(function() {
        step++;
        var ease = 1 - Math.pow(1 - step / steps, 3);
        var current = Math.round(target * ease);
        if (format === 'ars') {
          el.textContent = new Intl.NumberFormat('es-AR', {
            style: 'currency', currency: 'ARS',
            minimumFractionDigits: 0, maximumFractionDigits: 0,
          }).format(current);
        } else {
          el.textContent = current.toLocaleString('es-AR');
        }
        if (step >= steps) clearInterval(timer);
      }, 1000 / fps);
    }

    var metricEls = document.querySelectorAll('.mc-num');
    var metricStarted = false;
    var metricObs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && !metricStarted) {
        metricStarted = true;
        metricEls.forEach(function(el) {
          countUp(el, parseFloat(el.dataset.target) || 0, el.dataset.format || 'num');
        });
      }
    }, { threshold: 0.3 });
    var heroEl = document.querySelector('.hero-gestion');
    if (heroEl) metricObs.observe(heroEl);

    /* ── Timeline fade-in ──────────────────────────────────── */
    var tlObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); tlObs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.tl-item').forEach(function(el) { tlObs.observe(el); });

    /* ── Acordeón ──────────────────────────────────────────── */
    document.querySelectorAll('.acordeon-btn').forEach(function(btn) {
      var body = document.getElementById(btn.dataset.target);
      if (!body) return;
      btn.addEventListener('click', function() {
        var isOpen = !body.classList.contains('hidden');
        body.classList.toggle('hidden', isOpen);
        btn.classList.toggle('open', !isOpen);
      });
    });

    /* ── Evaluador IA (código original sin cambios) ─────────── */
    var datos;
    try { datos = JSON.parse(gestionPayload); } catch(e) { datos = {}; }

    function animarMetricas(scores) {
      var keys = ['transparencia','eficiencia','crecimiento','respuesta','calificacion'];
      keys.forEach(function(key) {
        var item = document.querySelector('[data-metric="' + key + '"]');
        if (!item) return;
        var val = Math.min(100, Math.max(0, Number(scores[key]) || 0));
        var fill = item.querySelector('.m-fill');
        var label = item.querySelector('.m-value');
        fill.className = 'm-fill ' + (val > 75 ? 'green' : val >= 50 ? 'yellow' : 'red');
        setTimeout(function() { fill.style.width = val + '%'; }, 50);
        var current = 0, stp = val / 40;
        var timer = setInterval(function() {
          current = Math.min(current + stp, val);
          label.textContent = Math.round(current) + '%';
          if (current >= val) clearInterval(timer);
        }, 30);
      });
    }

    var btnEvaluar = document.getElementById('btn-evaluar');
    var evalResult = document.getElementById('eval-result');
    var evalBody   = document.getElementById('eval-body');
    var evalClose  = document.getElementById('eval-close');

    btnEvaluar && btnEvaluar.addEventListener('click', async function() {
      evalResult && evalResult.classList.remove('hidden');
      btnEvaluar.classList.add('hidden');
      evalBody.textContent = 'Analizando gestión institucional...';
      btnEvaluar.disabled = true;
      try {
        var res = await fetch('/api/evaluar-gestion', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(datos),
        });
        var data = await res.json();
        if (data.evaluacion) {
          var e = data.evaluacion;
          animarMetricas(e);
          var partes = [];
          if (e.sintesis)  partes.push('📋 ' + e.sintesis);
          if (e.positivos) partes.push('✅ ' + e.positivos);
          if (e.mejoras)   partes.push('🔧 ' + e.mejoras);
          evalBody.textContent = partes.join('\n\n') || 'Evaluación completada.';
        } else {
          evalBody.textContent = data.error || 'No se pudo obtener la evaluación.';
        }
      } catch(err) {
        evalBody.textContent = 'Error de conexión. Intentá de nuevo.';
      } finally {
        btnEvaluar.disabled = false;
        btnEvaluar.classList.remove('hidden');
      }
    });

    evalClose && evalClose.addEventListener('click', function() {
      evalResult && evalResult.classList.add('hidden');
    });

    /* ── Analizar documentos individuales ─────────────────── */
    document.querySelectorAll('.btn-analizar-doc').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var fileItem = btn.closest('.file-item');
        var panel = fileItem && fileItem.querySelector('.doc-result');
        if (!panel) return;
        var tipo = btn.dataset.tipo;
        var doc;
        try { doc = JSON.parse(btn.dataset.doc); } catch(e) { return; }
        var payload = {
          memorias:     tipo === 'memoria'    ? [doc] : [],
          balances:     tipo === 'balance'    ? [doc] : [],
          resoluciones: tipo === 'resolucion' ? [doc] : [],
        };
        panel.classList.remove('hidden');
        panel.classList.add('loading');
        panel.textContent = '🤖 Analizando documento...';
        btn.disabled = true;
        try {
          var res = await fetch('/api/evaluar-gestion', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          var data = await res.json();
          panel.classList.remove('loading');
          if (data.evaluacion) {
            animarMetricas(data.evaluacion);
            panel.textContent = data.evaluacion.sintesis || 'Análisis completado.';
          } else {
            panel.textContent = data.error || 'No se pudo analizar.';
          }
        } catch(e) {
          panel.classList.remove('loading');
          panel.textContent = 'Error de conexión. Intentá de nuevo.';
        } finally {
          btn.disabled = false;
        }
      });
    });
  </script>

</MainLayout>
