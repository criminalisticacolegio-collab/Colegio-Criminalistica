---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const docs = await sanityClient.fetch(`*[_type == "bolsaTrabajo" && activo != false] | order(fechaPublicacion desc) {
  tipo, nombre, especialidades, jurisdiccion, modalidad, contacto, descripcion, matricula, fechaPublicacion
}`).catch(() => []);

const oferentes  = docs.filter((d: any) => d.tipo === 'oferente');
const demandantes = docs.filter((d: any) => d.tipo === 'demandante');

function fmtFecha(s: string) {
  if (!s) return '';
  const [y, m, d] = s.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<MainLayout title="Bolsa de Trabajo" showBack={true}>
  <div class="container page-content">
    <header class="section-header">
      <span class="sub-title">Empleo Profesional</span>
      <h1>Bolsa de Trabajo</h1>
      <p>Conectamos profesionales del CPCC con organismos y empresas que requieren servicios periciales.</p>
    </header>

    <!-- Tabs -->
    <div class="tabs-nav">
      <button class="tab-btn active" data-tab="oferentes">
        👤 Oferentes — Profesionales disponibles
        <span class="tab-count">{oferentes.length}</span>
      </button>
      <button class="tab-btn" data-tab="demandantes">
        🏢 Demandantes — Búsquedas activas
        <span class="tab-count">{demandantes.length}</span>
      </button>
    </div>

    <!-- Tab: Oferentes -->
    <div id="tab-oferentes" class="tab-content active">
      <div class="tab-toolbar">
        <div class="filters">
          <select id="filter-especialidad" class="filter-select">
            <option value="">Todas las especialidades</option>
          </select>
          <select id="filter-jurisdiccion-of" class="filter-select">
            <option value="">Todas las jurisdicciones</option>
          </select>
          <select id="filter-modalidad-of" class="filter-select">
            <option value="">Cualquier modalidad</option>
            <option value="presencial">Presencial</option>
            <option value="virtual">Virtual</option>
            <option value="mixta">Mixta</option>
          </select>
        </div>
      </div>

      {oferentes.length === 0 ? (
        <div class="empty-state glass">
          <span class="empty-icon">👤</span>
          <h3>Sin publicaciones de profesionales disponibles</h3>
          <p>Los matriculados activos pueden publicar su disponibilidad desde el panel de administración o completando el formulario de contacto.</p>
        </div>
      ) : (
        <div class="cards-grid" id="grid-oferentes">
          {oferentes.map((d: any) => (
            <div class="bolsa-card glass" data-esp={d.especialidades?.join(',').toLowerCase()} data-jur={d.jurisdiccion?.toLowerCase()} data-mod={d.modalidad?.toLowerCase()}>
              <div class="card-top">
                <div class="avatar-circle">👤</div>
                <div>
                  <h3>{d.nombre}</h3>
                  {d.matricula && <span class="mat-badge">Mat. {d.matricula}</span>}
                </div>
                <span class="tipo-badge green">Disponible</span>
              </div>
              {d.especialidades?.length > 0 && (
                <div class="tags-row">
                  {d.especialidades.map((e: string) => <span class="tag">{e}</span>)}
                </div>
              )}
              <div class="meta-row">
                {d.jurisdiccion && <span class="meta-item">📍 {d.jurisdiccion}</span>}
                {d.modalidad && <span class="meta-item">🔄 {d.modalidad}</span>}
                {d.fechaPublicacion && <span class="meta-item">📅 {fmtFecha(d.fechaPublicacion)}</span>}
              </div>
              {d.descripcion && <p class="card-desc">{d.descripcion}</p>}
              {d.contacto && (
                <a href={`mailto:${d.contacto}`} class="btn-contact-card">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
                  Contactar
                </a>
              )}
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Tab: Demandantes -->
    <div id="tab-demandantes" class="tab-content">
      <div class="tab-toolbar">
        <div class="filters">
          <select id="filter-jurisdiccion-dem" class="filter-select">
            <option value="">Todas las jurisdicciones</option>
          </select>
        </div>
      </div>

      {demandantes.length === 0 ? (
        <div class="empty-state glass">
          <span class="empty-icon">🏢</span>
          <h3>Sin búsquedas activas publicadas</h3>
          <p>Organismos y empresas pueden solicitar la publicación de sus búsquedas contactando a Secretaría del Colegio.</p>
        </div>
      ) : (
        <div class="cards-grid" id="grid-demandantes">
          {demandantes.map((d: any) => (
            <div class="bolsa-card glass" data-jur={d.jurisdiccion?.toLowerCase()}>
              <div class="card-top">
                <div class="avatar-circle org">🏢</div>
                <div>
                  <h3>{d.nombre}</h3>
                  <span class="tipo-badge blue">Busca profesional</span>
                </div>
              </div>
              {d.especialidades?.length > 0 && (
                <div class="tags-row">
                  <span class="tag-label">Busca:</span>
                  {d.especialidades.map((e: string) => <span class="tag">{e}</span>)}
                </div>
              )}
              <div class="meta-row">
                {d.jurisdiccion && <span class="meta-item">📍 {d.jurisdiccion}</span>}
                {d.modalidad && <span class="meta-item">🔄 {d.modalidad}</span>}
                {d.fechaPublicacion && <span class="meta-item">📅 {fmtFecha(d.fechaPublicacion)}</span>}
              </div>
              {d.descripcion && <p class="card-desc">{d.descripcion}</p>}
              {d.contacto && (
                <a href={`mailto:${d.contacto}`} class="btn-contact-card btn-blue">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
                  Contactar organismo
                </a>
              )}
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- CTA -->
    <div class="cta-box glass">
      <div class="cta-content">
        <h3>¿Querés publicar tu disponibilidad?</h3>
        <p>Si sos matriculado activo del CPCC, podés publicar tu perfil como profesional disponible. Contactá a Secretaría.</p>
      </div>
      <button onclick="window.toggleContactDrawer()" class="btn-cta">Contactar Secretaría</button>
    </div>
  </div>
</MainLayout>

<script>
  // Tabs
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab!;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`tab-${tab}`)?.classList.add('active');
    });
  });

  // Filtro especialidad
  const gridOf = document.getElementById('grid-oferentes');
  if (gridOf) {
    const cards = Array.from(gridOf.querySelectorAll<HTMLElement>('.bolsa-card'));
    const esps = new Set<string>();
    const jurs = new Set<string>();
    cards.forEach(c => {
      c.dataset.esp?.split(',').filter(Boolean).forEach(e => esps.add(e.trim()));
      if (c.dataset.jur) jurs.add(c.dataset.jur.trim());
    });
    const selEsp = document.getElementById('filter-especialidad') as HTMLSelectElement;
    const selJur = document.getElementById('filter-jurisdiccion-of') as HTMLSelectElement;
    const selMod = document.getElementById('filter-modalidad-of') as HTMLSelectElement;
    esps.forEach(e => { const o = document.createElement('option'); o.value = e; o.textContent = e; selEsp?.appendChild(o); });
    jurs.forEach(j => { const o = document.createElement('option'); o.value = j; o.textContent = j; selJur?.appendChild(o); });

    const applyFilters = () => {
      const esp = selEsp?.value; const jur = selJur?.value; const mod = selMod?.value;
      cards.forEach(c => {
        const matchEsp = !esp || (c.dataset.esp || '').includes(esp);
        const matchJur = !jur || c.dataset.jur === jur;
        const matchMod = !mod || c.dataset.mod === mod;
        c.style.display = matchEsp && matchJur && matchMod ? '' : 'none';
      });
    };
    selEsp?.addEventListener('change', applyFilters);
    selJur?.addEventListener('change', applyFilters);
    selMod?.addEventListener('change', applyFilters);
  }
</script>

<style>
  .page-content { padding: 5rem 0; display: flex; flex-direction: column; gap: 2.5rem; }
  .section-header { text-align: center; }
  .sub-title { color: var(--primary); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.9rem; display: block; margin-bottom: 1rem; }
  .section-header h1 { font-size: clamp(2rem, 5vw, 2.8rem); margin-bottom: 1rem; color: var(--accent); }
  .section-header p { font-size: 1.05rem; color: var(--text-light); max-width: 650px; margin: 0 auto; }

  .tabs-nav { display: flex; gap: 0; border-bottom: 2px solid var(--gray-200); }
  .tab-btn {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 1rem 1.5rem; background: none; border: none;
    border-bottom: 3px solid transparent; margin-bottom: -2px;
    font-family: inherit; font-size: 0.95rem; font-weight: 600;
    color: var(--text-light); cursor: pointer; transition: all 0.2s;
  }
  .tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); }
  .tab-btn:hover:not(.active) { color: var(--accent); background: var(--gray-50); }
  .tab-count { background: var(--gray-200); color: var(--text-light); font-size: 0.75rem; font-weight: 800; padding: 0.15rem 0.5rem; border-radius: 20px; }
  .tab-btn.active .tab-count { background: var(--primary); color: white; }

  .tab-content { display: none; }
  .tab-content.active { display: flex; flex-direction: column; gap: 1.5rem; }

  .tab-toolbar { display: flex; justify-content: space-between; align-items: center; }
  .filters { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .filter-select { padding: 0.5rem 0.75rem; border: 1px solid var(--gray-300); border-radius: 8px; font-family: inherit; font-size: 0.85rem; background: var(--white); color: var(--text-main); }

  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }

  .bolsa-card {
    padding: 1.75rem; border-radius: var(--radius-lg);
    border: 1px solid var(--gray-200); background: var(--white);
    display: flex; flex-direction: column; gap: 1rem;
    transition: var(--transition);
  }
  .bolsa-card:hover { border-color: var(--primary); transform: translateY(-4px); box-shadow: var(--shadow-md); }

  .card-top { display: flex; align-items: flex-start; gap: 1rem; }
  .avatar-circle { width: 48px; height: 48px; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
  .avatar-circle.org { background: #eff6ff; }
  .card-top h3 { font-size: 1rem; color: var(--accent); margin: 0 0 0.3rem; }
  .mat-badge { font-size: 0.72rem; color: var(--primary); font-weight: 700; background: var(--primary-light); padding: 0.15rem 0.5rem; border-radius: 20px; }
  .tipo-badge { margin-left: auto; font-size: 0.7rem; font-weight: 800; padding: 0.25rem 0.6rem; border-radius: 20px; white-space: nowrap; }
  .tipo-badge.green { background: #dcfce7; color: #166534; }
  .tipo-badge.blue { background: #dbeafe; color: #1d4ed8; }

  .tags-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .tag-label { font-size: 0.75rem; font-weight: 700; color: var(--text-light); }
  .tag { background: var(--gray-100); color: var(--text-main); font-size: 0.75rem; padding: 0.2rem 0.6rem; border-radius: 20px; }

  .meta-row { display: flex; gap: 1rem; flex-wrap: wrap; }
  .meta-item { font-size: 0.8rem; color: var(--text-light); }

  .card-desc { font-size: 0.85rem; color: var(--text-light); line-height: 1.5; }

  .btn-contact-card {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 1.2rem; background: var(--primary); color: white;
    border-radius: 8px; text-decoration: none; font-size: 0.85rem;
    font-weight: 700; transition: var(--transition); width: fit-content; margin-top: auto;
  }
  .btn-contact-card:hover { background: var(--primary-hover); }
  .btn-contact-card.btn-blue { background: #1d4ed8; }
  .btn-contact-card.btn-blue:hover { background: #1e40af; }

  .empty-state { text-align: center; padding: 4rem 2rem; border-radius: var(--radius-lg); border: 1px dashed var(--gray-300); }
  .empty-icon { font-size: 3rem; display: block; margin-bottom: 1.5rem; }
  .empty-state h3 { font-size: 1.4rem; margin-bottom: 1rem; color: var(--accent); }
  .empty-state p { color: var(--text-light); max-width: 500px; margin: 0 auto; line-height: 1.6; }

  .cta-box {
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
    padding: 2rem 2.5rem; border-radius: var(--radius-lg); border: 1px solid var(--gray-200);
  }
  .cta-content h3 { font-size: 1.15rem; color: var(--accent); margin-bottom: 0.4rem; }
  .cta-content p { font-size: 0.9rem; color: var(--text-light); line-height: 1.5; }
  .btn-cta { background: var(--primary); color: white; border: none; padding: 0.85rem 1.75rem; border-radius: var(--radius-md); font-weight: 700; cursor: pointer; transition: var(--transition); white-space: nowrap; font-family: inherit; }
  .btn-cta:hover { background: var(--primary-hover); }

  @media (max-width: 768px) {
    .tabs-nav { flex-direction: column; }
    .cta-box { flex-direction: column; text-align: center; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
