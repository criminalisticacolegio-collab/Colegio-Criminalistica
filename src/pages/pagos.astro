---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const config = await sanityClient.fetch(`*[_type == "configuracionCobros"][0]`);
const aranceles = await sanityClient.fetch(`*[_type == "arancelProfesional"] | order(valorEstimado asc)`);
---

<MainLayout title="Pagos y Aranceles" showBack={true}>
  <div id="pagos-config"
       data-cuota={config?.valorCuotaMensual || 0}
       data-anual={config?.valorMatriculaAnual || 0}
       class="hidden">
  </div>
	<div class="container page-content">
		<header class="section-header">
			<span class="sub-title">Administración</span>
			<h1>Aranceles y Pagos</h1>
			<p>Gestione sus cuotas, consulte aranceles de peritajes y realice pagos de forma segura.</p>
		</header>

		<div class="pagos-grid">
			<!-- Resumen de Cuenta -->
			<!-- Resumen de Cuenta Rediseñado -->
			<section class="payment-panel glass featured-panel">
				<div class="panel-badge-top">Recomendado</div>
				<div class="panel-header">
					<div class="header-main">
						<h2>Estado de Cuenta</h2>
						<p>Gestione su matrícula y cuotas vigentes</p>
					</div>
					<span class="status-badge active">Al Día</span>
				</div>
				
				<div class="deuda-summary-large">
					<div class="amount-card primary-card">
						<span class="label">Próximo Vencimiento (Cuota May-26)</span>
						<span class="value">${config?.valorCuotaMensual?.toLocaleString('es-AR')}</span>
						<button id="pay-monthly-btn" class="btn-pay-now">Pagar Cuota Mensual</button>
					</div>
					
					<div class="amount-card highlight-card">
						<div class="card-header">
							<span class="label">Matrícula Anual 2026</span>
							<span class="discount-badge">¡Ahorrá 20%!</span>
						</div>
						<span class="value">${config?.valorMatriculaAnual?.toLocaleString('es-AR')}</span>
						<p class="card-info">Pago único con bonificación por pago adelantado.</p>
						<button id="pay-annual-btn" class="btn-primary-large">PAGO MATRÍCULA ANUAL</button>
					</div>
				</div>

				<div class="payment-methods-compact">
					<h3>Métodos de pago habilitados</h3>
					<div class="methods-icons">
						<div class="m-icon-small" title="Visa">💳</div>
						<div class="m-icon-small" title="Mastercard">💳</div>
						<div class="m-icon-small" title="Transferencia">📱</div>
						<div class="m-icon-small" title="Mercado Pago">🏦</div>
					</div>
				</div>
			</section>

			<!-- Tabla de Aranceles -->
			<section class="aranceles-panel glass">
				<h2>Aranceles Profesionales Sugeridos</h2>
				<p class="panel-info">Valores vigentes según Resolución 04/2024</p>
				<table class="aranceles-table">
					<thead>
						<tr>
							<th>Servicio Pericial</th>
							<th>Unidades CP</th>
							<th>Valor Estimado</th>
						</tr>
					</thead>
					<tbody>
						{aranceles.map((item) => (
							<tr>
								<td>{item.servicio}</td>
								<td>{item.unidadesCP}</td>
								<td>${item.valorEstimado?.toLocaleString('es-AR')}</td>
							</tr>
						))}
					</tbody>
				</table>
				<div class="panel-footer">
					<button class="btn-download">Descargar PDF de Aranceles Completos</button>
				</div>
			</section>
		</div>
	</div>

	<style>
		.page-content { padding: 5rem 0; }
		.section-header { text-align: center; margin-bottom: 5rem; }
		.sub-title { color: var(--primary); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.9rem; display: block; margin-bottom: 1rem; }
		.section-header h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); margin-bottom: 1.5rem; color: var(--accent); }
		.section-header p { font-size: 1.25rem; color: var(--text-light); max-width: 800px; margin: 0 auto; }

		.pagos-grid {
			display: grid;
			grid-template-columns: 1.8fr 1fr;
			gap: 4rem;
			align-items: start;
		}

		.featured-panel {
			position: relative;
			border: 2px solid var(--primary-soft) !important;
			box-shadow: var(--shadow-lg) !important;
		}

		.panel-badge-top {
			position: absolute;
			top: -12px;
			right: 3rem;
			background: var(--primary);
			color: white;
			padding: 0.3rem 1rem;
			border-radius: 20px;
			font-size: 0.75rem;
			font-weight: 800;
			text-transform: uppercase;
		}

		.header-main h2 { margin-bottom: 0.25rem; font-size: 2rem; }
		.header-main p { color: var(--text-light); font-size: 0.95rem; }

		.deuda-summary-large {
			display: flex;
			flex-direction: column;
			gap: 2rem;
			margin: 2.5rem 0;
		}

		.amount-card {
			padding: 2.5rem;
			border-radius: 20px;
			border: 1px solid var(--gray-200);
			transition: var(--transition);
		}

		.primary-card { background: var(--gray-50); }
		
		.highlight-card {
			background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
			color: white;
			border: none;
			position: relative;
			overflow: hidden;
		}

		.highlight-card .label { color: var(--gray-400); }
		.highlight-card .value { color: white; font-size: 2.5rem; display: block; margin: 1rem 0; }
		.highlight-card .card-info { font-size: 0.9rem; color: var(--gray-300); margin-bottom: 2rem; }

		.card-header { display: flex; justify-content: space-between; align-items: center; }
		
		.discount-badge {
			background: #facc15;
			color: #422006;
			padding: 0.4rem 1rem;
			border-radius: 50px;
			font-weight: 800;
			font-size: 0.85rem;
		}

		.btn-pay-now {
			width: 100%;
			padding: 1rem;
			background: var(--white);
			border: 2px solid var(--primary);
			color: var(--primary);
			border-radius: 12px;
			font-weight: 700;
			cursor: pointer;
			margin-top: 1.5rem;
		}

		.btn-primary-large {
			width: 100%;
			padding: 1.25rem;
			background: var(--primary);
			color: white;
			border: none;
			border-radius: 12px;
			font-weight: 800;
			font-size: 1.1rem;
			cursor: pointer;
			transition: var(--transition);
			box-shadow: 0 10px 20px -10px var(--primary);
		}

		.btn-primary-large:hover {
			transform: translateY(-3px);
			filter: brightness(1.1);
		}

		.payment-methods-compact {
			border-top: 1px solid var(--gray-100);
			padding-top: 2rem;
		}

		.methods-icons {
			display: flex;
			gap: 1.5rem;
			margin-top: 1rem;
		}

		.m-icon-small {
			width: 45px;
			height: 45px;
			background: var(--gray-50);
			border-radius: 10px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.25rem;
			border: 1px solid var(--gray-200);
		}

		.status-badge.active { background: #dcfce7; color: #166534; }

		.amount-card .label { display: block; font-size: 0.85rem; color: var(--text-light); margin-bottom: 0.5rem; }
		.amount-card .value { font-size: 1.5rem; font-weight: 700; color: var(--primary); }

		.methods-grid {
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.method-btn {
			display: flex;
			align-items: center;
			gap: 1.25rem;
			padding: 1.25rem;
			background: var(--white);
			border: 1px solid var(--gray-200);
			border-radius: 12px;
			cursor: pointer;
			transition: var(--transition);
			text-align: left;
			width: 100%;
		}

		.method-btn:hover {
			border-color: var(--primary);
			transform: translateX(5px);
			background: var(--primary-soft);
		}

		.m-icon { font-size: 1.5rem; background: var(--gray-100); width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; border-radius: 10px; }
		.m-text strong { display: block; font-size: 1rem; color: var(--text-main); }
		.m-text span { font-size: 0.8rem; color: var(--text-light); }

		/* Table */
		.panel-info { color: var(--text-light); margin-bottom: 2rem; }
		.aranceles-table { width: 100%; border-collapse: collapse; margin-bottom: 2.5rem; }
		.aranceles-table th { text-align: left; padding: 1rem; border-bottom: 2px solid var(--gray-200); font-family: 'Outfit', sans-serif; color: var(--primary); }
		.aranceles-table td { padding: 1rem; border-bottom: 1px solid var(--gray-100); font-size: 0.95rem; }

		.btn-download {
			width: 100%;
			padding: 1rem;
			background: transparent;
			border: 2px solid var(--primary);
			color: var(--primary);
			border-radius: 12px;
			font-weight: 700;
			cursor: pointer;
			transition: var(--transition);
		}

		.btn-download:hover {
			background: var(--primary);
			color: white;
		}

		@media (max-width: 1024px) {
			.pagos-grid { grid-template-columns: 1fr; }
		}
	</style>
</MainLayout>

<script>
	import { auth } from '../lib/firebase';
	import { onAuthStateChanged } from 'firebase/auth';

	const configEl = document.getElementById('pagos-config') as HTMLElement;
	const valorCuota = Number(configEl?.dataset.cuota || 0);
	const valorAnual = Number(configEl?.dataset.anual || 0);

	const payMonthlyBtn = document.getElementById('pay-monthly-btn') as HTMLButtonElement;
	const payAnnualBtn = document.getElementById('pay-annual-btn') as HTMLButtonElement;

	let userEmail: string | null = null;

	onAuthStateChanged(auth, (user) => {
		userEmail = user?.email || null;
	});

	async function handlePayment(btn: HTMLButtonElement, amount: number, title: string) {
		if (!userEmail) {
			window.location.href = '/login';
			return;
		}
		const originalText = btn.innerHTML;
		btn.disabled = true;
		btn.textContent = 'Procesando...';
		try {
			const res = await fetch('/api/create-preference', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ amount, title, email: userEmail }),
			});
			const data = await res.json();
			if (data.init_point) {
				window.location.href = data.init_point;
			} else {
				throw new Error('Sin init_point');
			}
		} catch (err) {
			console.error('[pagos] Error pago:', err);
			alert('Error al iniciar el pago. Por favor reintente.');
			btn.disabled = false;
			btn.innerHTML = originalText;
		}
	}

	payMonthlyBtn?.addEventListener('click', () =>
		handlePayment(payMonthlyBtn, valorCuota, 'Cuota Social Mensual CPC CTM')
	);

	payAnnualBtn?.addEventListener('click', () =>
		handlePayment(payAnnualBtn, valorAnual, 'Matrícula Anual CPC CTM')
	);

	document.querySelector('.btn-download')?.addEventListener('click', () => {
		window.location.href = '/aranceles';
	});
</script>
