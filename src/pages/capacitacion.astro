  .cat-digital   { background: rgba(74,20,140,0.85); color: white; }

  /* Botón play sobre la imagen */
  .card-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
