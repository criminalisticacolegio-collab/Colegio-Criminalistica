---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';

const [config, contacto] = await Promise.all([
  sanityClient.fetch(`*[_type == "capacitacionConfig"][0]{
    descripcion,
    cursoDestacado,
    "cursos": cursos[activo != false] | order(orden asc) {
      ...,
      linkPagoExterno,
      linkPagoMatriculado,
      linkPagoPublico,
      linkClassroom,
      codigoClassroom,
      fechaInicio,
      fechaCierre,
      proximamente
    },
    materiales,
    centrosForenses
  }`),
  sanityClient.fetch(`*[_type == "contactoConfig"][0]{ whatsapp }`),
]);
const whatsappNum = contacto?.whatsapp || '';

const builder = imageUrlBuilder({ projectId: '8q7vz6co', dataset: 'production' });
function urlFor(source) {
  return source ? builder.image(source).width(800).auto('format').url() : null;
}

function getEmbedUrl(url) {
  if (!url) return null;
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
  const vim = url.match(/(?:vimeo\.com\/)(\d+)/);
  if (vim) return `https://player.vimeo.com/video/${vim[1]}`;
  return url;
}

function getYTThumb(url) {
  const match = url?.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  return match ? `https://img.youtube.com/vi/${match[1]}/maxresdefault.jpg` : null;
}

function getSanityFileUrl(asset) {
  if (!asset?._ref) return '#';
  // Sanity file ref: file-XXXX-pdf → https://cdn.sanity.io/files/projectId/dataset/XXXX.pdf
  const ref = asset._ref.replace('file-', '').replace(/-([^-]+)$/, '.$1');
  return `https://cdn.sanity.io/files/8q7vz6co/production/${ref}`;
}

const destacado   = config?.cursoDestacado?.activo ? config.cursoDestacado : null;
const cursos      = config?.cursos || [];
const materiales  = config?.materiales || [];
const centros     = config?.centrosForenses || [];
const categorias  = ['Todos', ...new Set(cursos.map(c => c.categoria).filter(Boolean))];
const descripcion = config?.descripcion || 'Plataforma integral de formación para la actualización profesional y científica.';

// Inscripción ya confirmada (redirigido desde MercadoPago)
const url = Astro.url;
const inscripcionOk = url.searchParams.get('inscripcion') === 'ok';

function badgeAcceso(tipoAcceso: string | undefined, precioNormal: number | undefined, proximamente: boolean) {
  if (proximamente) return { label: 'Próximamente', cls: 'access-prox' };
  if (!tipoAcceso || tipoAcceso === 'gratuito' || tipoAcceso === 'gratuito_publico' || tipoAcceso === 'gratuito_matriculados') return { label: '🟢 Gratuito', cls: 'access-free' };
  const p = (precioNormal || 0).toLocaleString('es-AR');
  return { label: `🟡 $${p}`, cls: 'access-paid' };
}
---

<MainLayout title="Capacitación" showBack={true}>

  <div id="cap-cfg" data-whatsapp={whatsappNum} style="display:none"></div>

  <!-- ════════════════════ BANNER: inscripción exitosa ═══════ -->
  {inscripcionOk && (
    <div class="success-banner" id="success-banner">
      ✅ ¡Inscripción confirmada! Recibirás un email con los detalles.
      <button onclick="document.getElementById('success-banner').remove()" class="banner-close">✕</button>
    </div>
  )}

  <!-- ════════════════════ MODAL de VIDEO ════════════════════ -->
  <div id="video-modal" class="vmodal-overlay" aria-modal="true" role="dialog" aria-hidden="true">
    <div class="vmodal-card">
      <button id="close-modal" class="vmodal-close" aria-label="Cerrar video">✕</button>
      <div class="vmodal-title-bar">
        <span id="modal-title" class="vmodal-title"></span>
      </div>
      <div class="vmodal-frame-wrapper">
        <iframe
          id="modal-iframe"
          src=""
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          frameborder="0"
          title="Video del curso"
        ></iframe>
      </div>
    </div>
  </div>

  <!-- ════════════════════ MODAL de INSCRIPCIÓN ═══════════════ -->
  <div id="enroll-modal" class="emodal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="emodal-card">
      <button id="enroll-close" class="emodal-close" aria-label="Cerrar">✕</button>

      <!-- Formulario principal -->
      <div id="emodal-step-form" class="emodal-step">
        <div class="emodal-header">
          <h3>Inscribirse al curso</h3>
          <p id="emodal-course-display" class="emodal-course-name"></p>
        </div>
        <div id="emodal-price-row" class="emodal-price-row"></div>
        <div class="emodal-form">
          <input type="text"  id="ef-nombre"     placeholder="Apellido y Nombre *" autocomplete="name" />
          <input type="text"  id="ef-dni"        placeholder="DNI *" inputmode="numeric" />
          <input type="text"  id="ef-profesion"  placeholder="Profesión / Título *" />
          <input type="text"  id="ef-institucion" placeholder="Institución / Organismo *" />
          <input type="text"  id="ef-cargo"      placeholder="Cargo *" />
          <input type="email" id="ef-email"      placeholder="Email *" autocomplete="email" />
          <input type="tel"   id="ef-tel"        placeholder="Teléfono *" autocomplete="tel" />
          <label class="ef-checkbox-label">
            <input type="checkbox" id="ef-es-matriculado" />
            <span>¿Es matriculado/a del CPCC?</span>
          </label>
          <div id="ef-mat-wrap" class="ef-mat-row emodal-hidden">
            <div style="display:flex;align-items:center;border:1.5px solid #ccc;border-radius:6px;padding:6px 10px;background:white;gap:2px;">
              <span style="color:#1a2d4a;font-weight:700;user-select:none;font-size:0.95rem;">MP-</span>
              <input type="text" id="ef-mat" placeholder="001" maxlength="4"
                style="border:none;outline:none;width:70px;font-size:0.95rem;font-family:inherit;" />
            </div>
            <span id="ef-mat-badge" class="ef-mat-badge emodal-hidden"></span>
          </div>
          <p id="emodal-error" class="emodal-error emodal-hidden"></p>
          <button id="emodal-submit" class="emodal-btn-primary">Confirmar inscripción</button>
        </div>
      </div>

      <!-- Pre-inscripción (cursos "Próximamente") -->
      <div id="emodal-step-preinsc" class="emodal-step emodal-hidden">
        <div class="emodal-header">
          <h3>Anotarme para avisos</h3>
          <p id="emodal-preinsc-course" class="emodal-course-name"></p>
        </div>
        <p class="emodal-preinsc-info">Te avisaremos cuando el curso esté disponible para inscripción.</p>
        <div class="emodal-form">
          <input type="text"  id="ef-preinsc-nombre" placeholder="Nombre y Apellido *" autocomplete="name" />
          <input type="email" id="ef-preinsc-email"  placeholder="Email *" autocomplete="email" />
          <p id="emodal-preinsc-error" class="emodal-error emodal-hidden"></p>
          <button id="emodal-preinsc-submit" class="emodal-btn-primary">Anotarme</button>
        </div>
      </div>

      <!-- Procesando -->
      <div id="emodal-step-processing" class="emodal-step emodal-hidden">
        <div class="emodal-spinner"></div>
        <p class="emodal-processing-text">Procesando tu inscripción…</p>
      </div>

      <!-- Éxito -->
      <div id="emodal-step-success" class="emodal-step emodal-hidden">
        <div class="emodal-success-icon">✅</div>
        <h3>¡Listo!</h3>
        <p id="emodal-success-msg" class="emodal-success-text">Recibirás un email con los detalles.</p>
        <button id="emodal-done" class="emodal-btn-primary">Cerrar</button>
      </div>

      <!-- Pago pendiente: instrucciones WhatsApp -->
      <div id="emodal-step-whatsapp" class="emodal-step emodal-hidden">
        <div class="emodal-success-icon">💳</div>
        <h3>¡Pre-inscripción registrada!</h3>
        <p class="emodal-success-text">Te abrimos la página de pago en una nueva pestaña. Una vez que tengas el comprobante, envialo por WhatsApp para activar tu acceso.</p>
        <a id="emodal-wa-btn" href="#" target="_blank" rel="noopener noreferrer" class="emodal-btn-whatsapp">
          💬 Enviar comprobante por WhatsApp
        </a>
        <button id="emodal-wa-done" class="emodal-btn-outline">Cerrar</button>
      </div>
    </div>
  </div>

  <div class="container page-content">

    <!-- ══════════════════ ENCABEZADO ══════════════════ -->
    <header class="section-header">
      <span class="sub-title">Campus Virtual</span>
      <h1>Formación Profesional</h1>
      <p>{descripcion}</p>
    </header>

    <!-- ══════════════════ HERO: CURSO DESTACADO ══════════════════ -->
    {destacado ? (
      <section class="featured-hero glass">
        <div class="hero-badge">{destacado.badge || 'Destacado'}</div>
        <div class="hero-grid">

          <!-- Video / Thumbnail -->
          <div class="hero-media" id="hero-media">
            {getEmbedUrl(destacado.videoUrl) ? (
              <div
                class="hero-thumb-wrapper"
                data-embed={getEmbedUrl(destacado.videoUrl)}
                id="hero-thumb-trigger"
                role="button"
                tabindex="0"
                aria-label={`Reproducir: ${destacado.titulo}`}
              >
                <img
                  src={getYTThumb(destacado.videoUrl) || '/placeholder-video.jpg'}
                  alt={destacado.titulo}
                  class="hero-thumb-img"
                  onerror="this.style.display='none'; this.nextElementSibling.style.background='#111';"
                />
                <div class="hero-play-overlay">
                  <div class="hero-play-btn" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="white" width="40" height="40">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                  <span>Reproducir video</span>
                </div>
              </div>
            ) : (
              <div class="hero-no-video">
                <div class="no-video-icon">🎓</div>
                <span>Próximamente</span>
              </div>
            )}
          </div>

          <!-- Detalle -->
          <div class="hero-details">
            <h2>{destacado.titulo}</h2>
            <p>{destacado.descripcion}</p>
            {(destacado.caracteristicas?.length > 0) && (
              <ul class="hero-feat-list">
                {destacado.caracteristicas.map(f => (
                  <li><span class="feat-check">✅</span>{f}</li>
                ))}
              </ul>
            )}
            <div class="hero-meta">
              {destacado.duracion && (
                <div class="hero-meta-item">
                  <span class="meta-icon">⏱</span>
                  <div><strong>{destacado.duracion}</strong><span>Duración</span></div>
                </div>
              )}
              {destacado.modulos && (
                <div class="hero-meta-item">
                  <span class="meta-icon">📚</span>
                  <div><strong>{destacado.modulos} módulos</strong><span>Contenido</span></div>
                </div>
              )}
            </div>
            {getEmbedUrl(destacado.videoUrl) && (
              <button
                class="btn-hero-play"
                data-embed={getEmbedUrl(destacado.videoUrl)}
                data-title={destacado.titulo}
              >
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M8 5v14l11-7z"/></svg>
                ▶ Ver Video en YouTube
              </button>
            )}
          </div>
        </div>
      </section>
    ) : (
      <!-- Placeholder si no hay curso destacado configurado en Sanity -->
      <section class="featured-hero glass placeholder-hero">
        <div class="hero-badge">Próximamente</div>
        <div class="placeholder-content">
          <div class="placeholder-icon">🎓</div>
          <h2>Curso Destacado</h2>
          <p>Configurá el curso destacado desde el panel de administración de Sanity.</p>
        </div>
      </section>
    )}

    <!-- ══════════════════ CURSOS Y SEMINARIOS ══════════════════ -->
    <section class="courses-section">
      <div class="section-title-alt">
        <h2>Cursos y Seminarios</h2>
        <div class="filters" id="filter-group" role="group" aria-label="Filtrar por categoría">
          {categorias.map((cat, i) => (
            <button
              class={`filter-btn${i === 0 ? ' active' : ''}`}
              data-filter={cat}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      {cursos.length > 0 ? (
        <div class="courses-grid" id="courses-grid">
          {cursos.map(course => {
            const imgSrc = course.imagen ? urlFor(course.imagen) : getYTThumb(course.videoUrl);
            const embedUrl = getEmbedUrl(course.videoUrl);
            return (
              <article
                class="course-card"
                data-cat={course.categoria || 'Todos'}
                aria-label={course.titulo}
              >
                <div class="card-media">
                  {imgSrc ? (
                    <img src={imgSrc} alt={course.titulo} loading="lazy" />
                  ) : (
                    <div class="card-img-placeholder">🎓</div>
                  )}

                  {course.categoria && (
                    <span class={`cat-badge cat-${(course.categoria || '').toLowerCase()}`}>
                      {course.categoria}
                    </span>
                  )}

                  {embedUrl && (
                    <button
                      class="card-play-btn"
                      data-embed={embedUrl}
                      data-title={course.titulo}
                      aria-label={`Ver video: ${course.titulo}`}
                    >
                      <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M8 5v14l11-7z"/></svg>
                    </button>
                  )}

                  <div class="card-meta-overlay">
                    {course.duracion && <span>⏱ {course.duracion}</span>}
                    {course.modulos && <span>📚 {course.modulos} mód.</span>}
                  </div>
                </div>

                <div class="card-body">
                  <h3>{course.titulo}</h3>

                  {(course.tipoAcceso === 'pago' || course.tipoAcceso === 'pago_publico' || course.tipoAcceso === 'pago_matriculados') && course.linkPagoMatriculado && (
                    <span style="background:#1a5c2a;color:white;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;display:inline-flex;align-items:center;gap:4px;">
                      ⭐ Matriculados con descuento
                    </span>
                  )}

                  {course.descripcion && <p>{course.descripcion}</p>}

                  {(() => {
                    const b = badgeAcceso(course.tipoAcceso, course.precioNormal, !!course.proximamente);
                    return <span class={`access-badge ${b.cls}`}>{b.label}</span>;
                  })()}

                  <div class="card-actions">
                    {embedUrl ? (
                      <button
                        class="btn-watch"
                        data-embed={embedUrl}
                        data-title={course.titulo}
                      >
                        <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M8 5v14l11-7z"/></svg>
                        ▶ Ver Video en YouTube
                      </button>
                    ) : (
                      <span class="no-video-badge">Sin video aún</span>
                    )}

                    {course._key && (
                      <button
                        class="btn-inscribir"
                        data-key={course._key}
                        data-titulo={course.titulo}
                        data-tipo={course.tipoAcceso || 'gratuito'}
                        data-precio={String(course.precioNormal ?? '')}
                        data-precio-mat={String(course.precioMatriculado ?? '')}
                        data-link-externo={course.linkPagoExterno || ''}
                        data-link-pago-mat={course.linkPagoMatriculado || ''}
                        data-link-pago-pub={course.linkPagoPublico || ''}
                        data-link-classroom={course.linkClassroom || ''}
                        data-codigo-classroom={course.codigoClassroom || ''}
                        data-fecha-inicio={course.fechaInicio || ''}
                        data-proximamente={course.proximamente ? 'true' : 'false'}
                      >
                        {course.proximamente
                          ? 'Anotarme para avisos'
                          : (!course.tipoAcceso || course.tipoAcceso === 'gratuito' || course.tipoAcceso === 'gratuito_publico' || course.tipoAcceso === 'gratuito_matriculados')
                            ? 'Inscribirse gratis'
                            : `Inscribirse — $${(course.precioNormal || 0).toLocaleString('es-AR')}`}
                      </button>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="empty-courses">
          <div class="empty-icon">📋</div>
          <h3>Sin cursos publicados</h3>
          <p>Agregá cursos desde el panel de Sanity Studio en <code>/admin-colegio</code>.</p>
        </div>
      )}
    </section>

    <!-- ══════════════════ MATERIALES DESCARGABLES ══════════════════ -->
    {materiales.length > 0 && (
      <section class="materials-section glass">
        <div class="materials-header">
          <div>
            <h3>Materiales Descargables</h3>
            <p>Documentos, protocolos y bibliografía para tu práctica profesional.</p>
          </div>
        </div>
        <div class="materials-grid">
          {materiales.map(mat => (
            <a
              href={getSanityFileUrl(mat.archivo?.asset)}
              class="material-card"
              target="_blank"
              rel="noopener noreferrer"
              download
            >
              <span class="mat-icon">{mat.icono || '📄'}</span>
              <div class="mat-info">
                <strong>{mat.titulo}</strong>
                {mat.descripcion && <span>{mat.descripcion}</span>}
              </div>
              <span class="mat-arrow">↓</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ══════════════════ CENTROS DE REFERENCIA ══════════════════ -->
    {centros.length > 0 && (
      <section class="centros-section">
        <div class="centros-header">
          <h3>🔬 Centros Criminalísticos de Referencia</h3>
          <p>Recursos externos de instituciones líderes para ampliar tu formación profesional.</p>
        </div>
        <div class="centros-grid">
          {centros.map((c: any, i: number) => {
            const GRADIENTS = [
              'linear-gradient(135deg, #1a3a5c, #2d6a9f)',
              'linear-gradient(135deg, #2d5a1b, #4a9a2e)',
              'linear-gradient(135deg, #5c3a1a, #9f6a2d)',
              'linear-gradient(135deg, #1a2d4a, #2d4a6a)',
              'linear-gradient(135deg, #3a1a5c, #6a2d9f)',
            ];
            const gradient = GRADIENTS[i % GRADIENTS.length];
            let dominio = '';
            try { dominio = new URL(c.url).hostname; } catch {}
            return (
              <div class="enlace-card">
                <div class="enlace-preview" style={`background: ${gradient}`}>
                  <img
                    src={`https://www.google.com/s2/favicons?domain=${dominio}&sz=256`}
                    alt=""
                    width="72" height="72"
                    style="width:72px;height:72px;object-fit:contain;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,0.25);"
                    onerror="this.style.display='none'"
                  />
                  <span class="dominio">{dominio}</span>
                </div>
                <div class="enlace-body">
                  <div class="enlace-categoria">Centro de referencia</div>
                  <div class="enlace-titulo">{c.nombre}</div>
                  {c.descripcion && <p class="enlace-desc">{c.descripcion}</p>}
                  <a href={c.url} target="_blank" rel="noopener noreferrer" class="enlace-btn">
                    Visitar sitio →
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

  </div><!-- /container -->
</MainLayout>

<!-- ════════════════════════════════════════════════════════ -->
<script>
  // ── Inscripción ───────────────────────────────────────────
  interface CourseData {
    key: string; titulo: string; tipo: string;
    precio: string; precioMat: string;
    linkExterno: string; linkPagoMat: string; linkPagoPub: string;
    linkClassroom: string; codigoClassroom: string;
    fechaInicio: string; proximamente: boolean;
  }

  let currentCourse: CourseData | null = null;
  let matVerificada = false;
  let precioFinal = 0;

  const whatsappNum = (document.getElementById('cap-cfg') as HTMLElement)?.dataset.whatsapp || '';

  const enrollModal    = document.getElementById('enroll-modal') as HTMLDivElement;
  const stepForm       = document.getElementById('emodal-step-form') as HTMLDivElement;
  const stepPreinsc    = document.getElementById('emodal-step-preinsc') as HTMLDivElement;
  const stepProcess    = document.getElementById('emodal-step-processing') as HTMLDivElement;
  const stepSuccess    = document.getElementById('emodal-step-success') as HTMLDivElement;
  const stepWhatsapp   = document.getElementById('emodal-step-whatsapp') as HTMLDivElement;
  const errorEl        = document.getElementById('emodal-error') as HTMLParagraphElement;
  const priceRow       = document.getElementById('emodal-price-row') as HTMLDivElement;
  const courseDisplay  = document.getElementById('emodal-course-display') as HTMLParagraphElement;
  const successMsg     = document.getElementById('emodal-success-msg') as HTMLParagraphElement;
  const submitBtn      = document.getElementById('emodal-submit') as HTMLButtonElement;
  const matInput       = document.getElementById('ef-mat') as HTMLInputElement;
  const matBadge       = document.getElementById('ef-mat-badge') as HTMLSpanElement;
  const matWrap        = document.getElementById('ef-mat-wrap') as HTMLDivElement;
  const esMatriculadoCb = document.getElementById('ef-es-matriculado') as HTMLInputElement;

  function showStep(step: 'form' | 'preinsc' | 'processing' | 'success' | 'whatsapp') {
    stepForm.classList.toggle('emodal-hidden', step !== 'form');
    stepPreinsc.classList.toggle('emodal-hidden', step !== 'preinsc');
    stepProcess.classList.toggle('emodal-hidden', step !== 'processing');
    stepSuccess.classList.toggle('emodal-hidden', step !== 'success');
    stepWhatsapp.classList.toggle('emodal-hidden', step !== 'whatsapp');
  }

  function updatePrice() {
    if (!currentCourse) return;
    const tipo = currentCourse.tipo;
    const esGratuito = !tipo || tipo === 'gratuito' || tipo === 'gratuito_publico' || tipo === 'gratuito_matriculados';
    const precioPublico = Number(currentCourse.precio) || 0;
    const precioMat     = Number(currentCourse.precioMat) || 0;

    if (esGratuito) {
      precioFinal = 0;
      priceRow.innerHTML = '<span class="eprice-badge eprice-free">🟢 Acceso gratuito</span>';
      submitBtn.textContent = 'Confirmar inscripción gratuita';
      return;
    }
    if (matVerificada && precioMat > 0) {
      precioFinal = precioMat;
      priceRow.innerHTML = `<span class="eprice-badge eprice-mat">✅ Matrícula verificada — Precio matriculado: $${precioMat.toLocaleString('es-AR')}</span>`;
    } else {
      precioFinal = precioPublico;
      priceRow.innerHTML = `<span class="eprice-badge eprice-paid">$${precioPublico.toLocaleString('es-AR')}</span>`;
    }
    submitBtn.textContent = `🔗 Inscribirse y pagar $${precioFinal.toLocaleString('es-AR')}`;
  }

  function openEnrollModal(course: CourseData) {
    currentCourse = course;
    matVerificada = false;
    precioFinal = 0;

    if (course.proximamente) {
      (document.getElementById('emodal-preinsc-course') as HTMLElement).textContent = course.titulo;
      (document.getElementById('ef-preinsc-nombre') as HTMLInputElement).value = '';
      (document.getElementById('ef-preinsc-email') as HTMLInputElement).value = '';
      (document.getElementById('emodal-preinsc-error') as HTMLElement).classList.add('emodal-hidden');
      showStep('preinsc');
    } else {
      courseDisplay.textContent = course.titulo;
      (document.getElementById('ef-nombre') as HTMLInputElement).value = '';
      (document.getElementById('ef-dni') as HTMLInputElement).value = '';
      (document.getElementById('ef-profesion') as HTMLInputElement).value = '';
      (document.getElementById('ef-institucion') as HTMLInputElement).value = '';
      (document.getElementById('ef-cargo') as HTMLInputElement).value = '';
      (document.getElementById('ef-email') as HTMLInputElement).value = '';
      (document.getElementById('ef-tel') as HTMLInputElement).value = '';
      esMatriculadoCb.checked = false;
      matWrap.classList.add('emodal-hidden');
      matInput.value = '';
      matBadge.classList.add('emodal-hidden');
      matVerificada = false;
      errorEl.classList.add('emodal-hidden');
      updatePrice();
      showStep('form');
    }

    enrollModal.setAttribute('aria-hidden', 'false');
    enrollModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeEnrollModal() {
    enrollModal.setAttribute('aria-hidden', 'true');
    enrollModal.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Checkbox matriculado: mostrar/ocultar campo de matrícula
  esMatriculadoCb?.addEventListener('change', () => {
    matWrap.classList.toggle('emodal-hidden', !esMatriculadoCb.checked);
    if (!esMatriculadoCb.checked) {
      matInput.value = '';
      matBadge.classList.add('emodal-hidden');
      matVerificada = false;
      updatePrice();
    }
  });

  // Verificación de matrícula (debounced)
  let matTimer: ReturnType<typeof setTimeout>;
  matInput?.addEventListener('input', () => {
    clearTimeout(matTimer);
    const raw = matInput.value.trim();
    matBadge.classList.add('emodal-hidden');
    matVerificada = false;
    updatePrice();
    if (raw.length < 1) return;
    const val = 'MP-' + raw.padStart(3, '0');
    matTimer = setTimeout(async () => {
      try {
        const res = await fetch('/api/verificar-matricula', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ numeroMatricula: val }),
        });
        const data = await res.json();
        matVerificada = data.ok === true;
        matBadge.textContent = matVerificada
          ? `✅ Matrícula verificada${data.nombre ? ` — ${data.nombre}` : ''}`
          : `❌ ${data.error || 'No encontrada'}`;
        matBadge.className = `ef-mat-badge ${matVerificada ? 'ef-mat-ok' : 'ef-mat-error'}`;
        matBadge.classList.remove('emodal-hidden');
        updatePrice();
      } catch {
        matBadge.textContent = '❌ Error al verificar. Intentá de nuevo.';
        matBadge.className = 'ef-mat-badge ef-mat-error';
        matBadge.classList.remove('emodal-hidden');
      }
    }, 600);
  });

  // Abrir modal
  document.querySelectorAll<HTMLButtonElement>('.btn-inscribir').forEach(btn => {
    btn.addEventListener('click', () => {
      openEnrollModal({
        key:             btn.dataset.key!,
        titulo:          btn.dataset.titulo!,
        tipo:            btn.dataset.tipo || 'gratuito_publico',
        precio:          btn.dataset.precio || '0',
        precioMat:       btn.dataset.precioMat || '',
        linkExterno:     btn.dataset.linkExterno || '',
        linkPagoMat:     btn.dataset.linkPagoMat || '',
        linkPagoPub:     btn.dataset.linkPagoPub || '',
        linkClassroom:   btn.dataset.linkClassroom || '',
        codigoClassroom: btn.dataset.codigoClassroom || '',
        fechaInicio:     btn.dataset.fechaInicio || '',
        proximamente:    btn.dataset.proximamente === 'true',
      });
    });
  });

  // Submit inscripción principal
  submitBtn?.addEventListener('click', async () => {
    if (!currentCourse) return;
    const nombre    = (document.getElementById('ef-nombre')     as HTMLInputElement).value.trim();
    const dni       = (document.getElementById('ef-dni')        as HTMLInputElement).value.trim();
    const profesion = (document.getElementById('ef-profesion')  as HTMLInputElement).value.trim();
    const institucion = (document.getElementById('ef-institucion') as HTMLInputElement).value.trim();
    const cargo     = (document.getElementById('ef-cargo')      as HTMLInputElement).value.trim();
    const email     = (document.getElementById('ef-email')      as HTMLInputElement).value.trim();
    const tel       = (document.getElementById('ef-tel')        as HTMLInputElement).value.trim();
    const matRaw    = matInput.value.trim();
    const mat       = esMatriculadoCb.checked && matRaw ? 'MP-' + matRaw.padStart(3, '0') : '';

    if (!nombre || !dni || !profesion || !institucion || !cargo || !email || !tel) {
      errorEl.textContent = 'Completá todos los campos obligatorios (*).';
      errorEl.classList.remove('emodal-hidden');
      return;
    }
    if (esMatriculadoCb.checked && !mat) {
      errorEl.textContent = 'Ingresá tu número de matrícula o desmarcá la casilla.';
      errorEl.classList.remove('emodal-hidden');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent = 'Email inválido.';
      errorEl.classList.remove('emodal-hidden');
      return;
    }

    errorEl.classList.add('emodal-hidden');
    const tipo = currentCourse.tipo;
    const esGratuito = !tipo || tipo === 'gratuito' || tipo === 'gratuito_publico' || tipo === 'gratuito_matriculados';

    // ── CASO GRATUITO ────────────────────────────────────────
    if (esGratuito) {
      showStep('processing');
      try {
        const res = await fetch('/api/inscribir-curso', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            cursoKey: currentCourse.key, cursoNombre: currentCourse.titulo,
            nombreCompleto: nombre, dni, email, telefono: tel,
            profesion, institucion, cargo,
            numeroMatricula: mat || undefined, precioAbonado: 0,
            esGratuito: true,
            linkClassroom: currentCourse.linkClassroom,
            codigoClassroom: currentCourse.codigoClassroom,
            fechaInicio: currentCourse.fechaInicio,
          }),
        });
        const data = await res.json();
        if (!res.ok || data.error) {
          showStep('form');
          errorEl.textContent = data.error || 'Error al procesar. Intentá de nuevo.';
          errorEl.classList.remove('emodal-hidden');
          return;
        }
        successMsg.textContent = data.message || `¡Inscripción confirmada! Revisá tu email ${email}.`;
        showStep('success');
      } catch {
        showStep('form');
        errorEl.textContent = 'Error de conexión. Verificá tu internet e intentá de nuevo.';
        errorEl.classList.remove('emodal-hidden');
      }
      return;
    }

    // ── CASO PAGO ────────────────────────────────────────────
    // El servidor verifica email+matrícula y devuelve el link correcto
    showStep('processing');
    let linkPago = currentCourse.linkPagoPub || currentCourse.linkExterno; // fallback client
    try {
      const res = await fetch('/api/inscribir-curso', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          cursoKey: currentCourse.key, cursoNombre: currentCourse.titulo,
          nombreCompleto: nombre, dni, email, telefono: tel,
          profesion, institucion, cargo,
          numeroMatricula: mat || undefined, precioAbonado: precioFinal,
          esGratuito: false,
          linkClassroom: currentCourse.linkClassroom,
          codigoClassroom: currentCourse.codigoClassroom,
          fechaInicio: currentCourse.fechaInicio,
        }),
      });
      const data = await res.json();
      if (data.linkPago) linkPago = data.linkPago;
    } catch { /* usa fallback client */ }

    // Abrir link de pago en nueva pestaña
    if (linkPago) {
      window.open(linkPago, '_blank', 'noopener,noreferrer');
    }

    // Preparar y mostrar tarjeta WhatsApp
    const waMsg = encodeURIComponent(
      `Hola! Acabo de inscribirme al curso ${currentCourse.titulo}. Mi nombre es ${nombre}. Adjunto comprobante de pago.`
    );
    const waNum = whatsappNum.replace(/\D/g, '');
    const waLink = waNum ? `https://wa.me/${waNum}?text=${waMsg}` : `https://wa.me/?text=${waMsg}`;
    (document.getElementById('emodal-wa-btn') as HTMLAnchorElement).href = waLink;
    showStep('whatsapp');
  });

  // Submit pre-inscripción
  document.getElementById('emodal-preinsc-submit')?.addEventListener('click', async () => {
    const nombre = (document.getElementById('ef-preinsc-nombre') as HTMLInputElement).value.trim();
    const email  = (document.getElementById('ef-preinsc-email')  as HTMLInputElement).value.trim();
    const errEl  = document.getElementById('emodal-preinsc-error') as HTMLElement;
    if (!nombre || !email) {
      errEl.textContent = 'Completá nombre y email.';
      errEl.classList.remove('emodal-hidden');
      return;
    }
    errEl.classList.add('emodal-hidden');
    showStep('processing');
    try {
      const res = await fetch('/api/inscribir-curso', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          cursoKey: currentCourse!.key, cursoNombre: currentCourse!.titulo,
          nombreCompleto: nombre, email, esPreinscripcion: true, esGratuito: true,
        }),
      });
      const data = await res.json();
      successMsg.textContent = data.message || '¡Listo! Te avisaremos cuando esté disponible.';
      showStep('success');
    } catch {
      showStep('preinsc');
      errEl.textContent = 'Error de conexión. Intentá de nuevo.';
      errEl.classList.remove('emodal-hidden');
    }
  });

  document.getElementById('enroll-close')?.addEventListener('click', closeEnrollModal);
  document.getElementById('emodal-done')?.addEventListener('click', closeEnrollModal);
  document.getElementById('emodal-wa-done')?.addEventListener('click', closeEnrollModal);
  enrollModal?.addEventListener('click', (e) => { if (e.target === enrollModal) closeEnrollModal(); });

  // ── Helpers ───────────────────────────────────────────────
  const modal     = document.getElementById('video-modal') as HTMLDivElement;
  const iframe    = document.getElementById('modal-iframe') as HTMLIFrameElement;
  const modalTitle = document.getElementById('modal-title') as HTMLSpanElement;
  const closeBtn  = document.getElementById('close-modal') as HTMLButtonElement;

  function openModal(embedUrl: string, title: string) {
    iframe.src = embedUrl + '?autoplay=1&rel=0';
    modalTitle.textContent = title;
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    iframe.src = '';
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeModal();
      closeEnrollModal();
    }
  });

  // ── Botones de video: modal en página (fallback nueva pestaña) ─
  function embedToWatchUrl(embedUrl: string): string {
    const ytMatch = embedUrl.match(/youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/);
    if (ytMatch) return `https://www.youtube.com/watch?v=${ytMatch[1]}`;
    const vimeoMatch = embedUrl.match(/player\.vimeo\.com\/video\/(\d+)/);
    if (vimeoMatch) return `https://vimeo.com/${vimeoMatch[1]}`;
    return embedUrl;
  }

  document.querySelectorAll<HTMLButtonElement>('[data-embed][data-title]').forEach(btn => {
    btn.addEventListener('click', () => {
      const embed = btn.dataset.embed!;
      const title = btn.dataset.title!;
      if (modal && iframe) {
        openModal(embed, title);
      } else {
        window.open(embedToWatchUrl(embed), '_blank', 'noopener,noreferrer');
      }
    });
  });

  // ── Hero: click en thumbnail → reproduce inline ──────────
  const heroTrigger = document.getElementById('hero-thumb-trigger') as HTMLDivElement | null;
  if (heroTrigger) {
    const activateHero = () => {
      const embedUrl = heroTrigger.dataset.embed!;
      const heroMedia = document.getElementById('hero-media') as HTMLDivElement;
      const ifr = document.createElement('iframe');
      ifr.src = embedUrl + '?autoplay=1&rel=0';
      ifr.allow = 'autoplay; fullscreen; picture-in-picture';
      ifr.allowFullscreen = true;
      ifr.title = 'Video del curso destacado';
      ifr.style.cssText = 'width:100%;height:100%;border:none;';
      heroMedia.style.background = '#000';
      heroMedia.innerHTML = '';
      heroMedia.appendChild(ifr);
    };
    heroTrigger.addEventListener('click', activateHero);
    heroTrigger.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') activateHero(); });
  }

  // ── Filtros de categoría ──────────────────────────────────
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards      = document.querySelectorAll<HTMLElement>('.course-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      filterBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach(card => {
        const cat = card.dataset.cat || 'Todos';
        const show = filter === 'Todos' || cat === filter;
        card.style.display = show ? '' : 'none';
        card.style.animation = show ? 'fadeIn 0.25s ease' : '';
      });
    });
  });
</script>

<style>
