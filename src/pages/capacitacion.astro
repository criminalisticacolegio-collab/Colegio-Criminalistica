---
import MainLayout from '../layouts/MainLayout.astro';

const courses = [
	{ id: 1, title: 'Introducción al Peritaje Judicial', duration: '10hs', modules: 4, image: 'https://images.unsplash.com/photo-1577412647305-991150c7d163?auto=format&fit=crop&q=80&w=800' },
	{ id: 2, title: 'Documentoscopia Avanzada', duration: '25hs', modules: 8, image: 'https://images.unsplash.com/photo-1503551723145-6c040742065b?auto=format&fit=crop&q=80&w=800' },
	{ id: 3, title: 'Informática Forense I', duration: '15hs', modules: 6, image: 'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=800' },
];
---

<MainLayout title="Capacitación" showBack={true}>
	<div class="container page-content">
		<header class="section-header">
			<span class="sub-title">Campus Virtual</span>
			<h1>Capacitación Continua</h1>
			<p>Plataforma integral de formación para la actualización profesional y científica.</p>
		</header>

		<section class="featured-lms glass">
			<div class="lms-badge">En Vivo</div>
			<div class="featured-grid">
				<div class="featured-video">
					<div class="video-placeholder">
						<div class="play-btn">▶</div>
						<span>Previsualización del Curso</span>
					</div>
				</div>
				<div class="featured-details">
					<h2>Diplomatura en Criminalística Digital</h2>
					<p>Un recorrido exhaustivo por las nuevas fronteras de la evidencia informática y el peritaje en entornos virtuales. Incluye prácticas en laboratorio remoto.</p>
					<ul class="feat-list">
						<li>✅ 40 Horas de contenido</li>
						<li>✅ Clases sincrónicas y asincrónicas</li>
						<li>✅ Examen final con certificación oficial</li>
					</ul>
					<button class="btn-primary">Inscribirme ahora</button>
				</div>
			</div>
		</section>

		<section class="courses-section">
			<div class="section-title-alt">
				<h2>Cursos y Seminarios</h2>
				<div class="filters">
					<button class="filter-btn active">Todos</button>
					<button class="filter-btn">Pericial</button>
					<button class="filter-btn">Legal</button>
					<button class="filter-btn">Técnico</button>
				</div>
			</div>

			<div class="courses-grid">
				{courses.map(course => (
					<div class="course-card">
						<div class="card-image">
							<img src={course.image} alt={course.title} />
							<div class="meta-overlay">
								<span>{course.duration}</span>
								<span>{course.modules} Módulos</span>
							</div>
						</div>
						<div class="card-body">
							<h3>{course.title}</h3>
							<p>Contenido actualizado según las últimas normativas vigentes en la provincia.</p>
							<div class="card-footer">
								<a href="#" class="link-more">Ver detalles →</a>
								<button class="btn-sm">Acceder</button>
							</div>
						</div>
					</div>
				))}
			</div>
		</section>

		<section class="material-download glass">
			<div class="material-content">
				<h3>Material y Biblioteca</h3>
				<p>Acceda a guías rápidas, protocolos de actuación y bibliografía recomendada para sus peritajes.</p>
			</div>
			<div class="material-actions">
				<a href="#" class="download-item">
					<span class="icon">📄</span>
					<div class="d-text">
						<strong>Guía Procedimiento</strong>
						<span>PDF - 2.4 MB</span>
					</div>
				</a>
				<a href="#" class="download-item">
					<span class="icon">📁</span>
					<div class="d-text">
						<strong>Protocolos 2024</strong>
						<span>ZIP - 15.0 MB</span>
					</div>
				</a>
			</div>
		</section>
	</div>

	<style>
		.page-content { padding: 5rem 0; }
		
		.section-header { text-align: center; margin-bottom: 5rem; }
		.sub-title { color: var(--primary); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.9rem; display: block; margin-bottom: 1rem; }
		.section-header h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); margin-bottom: 1.5rem; color: var(--accent); }
		.section-header p { font-size: 1.25rem; color: var(--text-light); max-width: 800px; margin: 0 auto; }

		.featured-lms { border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--gray-300); margin-bottom: 7rem; position: relative; }
		.lms-badge { position: absolute; top: 1.5rem; left: 1.5rem; background: #e74c3c; color: white; padding: 0.35rem 1rem; border-radius: 20px; font-weight: 700; font-size: 0.75rem; z-index: 10; animation: pulse 2s infinite; }
		
		@keyframes pulse {
			0% { opacity: 1; }
			50% { opacity: 0.7; }
			100% { opacity: 1; }
		}

		.featured-grid { display: grid; grid-template-columns: 1.25fr 1fr; }
		.featured-video { background: #000; display: flex; align-items: center; justify-content: center; min-height: 400px; }
		.video-placeholder { text-align: center; color: white; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
		.play-btn { width: 80px; height: 80px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; border: 4px solid rgba(255,255,255,0.2); transition: var(--transition); cursor: pointer; }
		.play-btn:hover { transform: scale(1.1); background: var(--primary-hover); }
		
		.featured-details { padding: 4rem; display: flex; flex-direction: column; justify-content: center; }
		.featured-details h2 { font-size: 2.25rem; margin-bottom: 1.5rem; }
		.featured-details p { font-size: 1.1rem; line-height: 1.7; color: var(--text-light); margin-bottom: 2rem; }
		.feat-list { list-style: none; margin-bottom: 2.5rem; }
		.feat-list li { margin-bottom: 0.75rem; font-weight: 600; color: var(--accent); }

		.btn-primary { background: var(--primary); color: white; border: none; padding: 1.1rem 2rem; border-radius: var(--radius-md); font-weight: 700; cursor: pointer; font-size: 1rem; width: fit-content; transition: var(--transition); }
		.btn-primary:hover { background: var(--primary-hover); transform: translateY(-2px); box-shadow: var(--shadow-md); }

		.section-title-alt { display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem; }
		.filters { display: flex; gap: 0.75rem; }
		.filter-btn { background: var(--white); border: 1px solid var(--gray-300); padding: 0.5rem 1.25rem; border-radius: 30px; font-weight: 600; cursor: pointer; transition: var(--transition); }
		.filter-btn.active, .filter-btn:hover { background: var(--primary); border-color: var(--primary); color: white; }

		.courses-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; margin-bottom: 7rem; }
		.course-card { background: var(--white); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--gray-200); transition: var(--transition); }
		.course-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); border-color: var(--primary); }
		.card-image { height: 200px; position: relative; }
		.card-image img { width: 100%; height: 100%; object-fit: cover; }
		.meta-overlay { position: absolute; bottom: 1rem; right: 1rem; background: rgba(0,0,0,0.7); color: white; padding: 0.4rem 0.8rem; border-radius: 8px; font-size: 0.8rem; display: flex; gap: 0.75rem; font-weight: 600; }

		.card-body { padding: 1.75rem; }
		.card-body h3 { font-size: 1.25rem; margin-bottom: 0.75rem; }
		.card-body p { font-size: 0.95rem; color: var(--text-light); line-height: 1.6; margin-bottom: 1.5rem; }
		.card-footer { display: flex; justify-content: space-between; align-items: center; }
		.link-more { color: var(--primary); text-decoration: none; font-weight: 700; font-size: 0.9rem; }
		.btn-sm { background: var(--gray-100); border: 1px solid var(--gray-300); padding: 0.5rem 1rem; border-radius: 8px; font-weight: 700; font-size: 0.85rem; cursor: pointer; transition: var(--transition); }
		.btn-sm:hover { background: var(--primary-light); border-color: var(--primary); color: var(--primary); }

		.material-download { padding: 3rem; border-radius: var(--radius-lg); display: flex; justify-content: space-between; align-items: center; gap: 3rem; }
		.material-content h3 { font-size: 1.75rem; margin-bottom: 0.75rem; }
		.material-content p { color: var(--text-light); max-width: 500px; }
		.material-actions { display: flex; gap: 1.5rem; }
		.download-item { background: var(--white); padding: 1rem 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--gray-200); display: flex; align-items: center; gap: 1rem; text-decoration: none; color: var(--text-main); transition: var(--transition); }
		.download-item:hover { border-color: var(--primary); transform: translateY(-3px); box-shadow: var(--shadow-sm); }
		.download-item .icon { font-size: 1.5rem; }
		.d-text { display: flex; flex-direction: column; }
		.d-text strong { font-size: 0.9rem; }
		.d-text span { font-size: 0.75rem; color: var(--text-light); }

		@media (max-width: 1024px) {
			.featured-grid { grid-template-columns: 1fr; }
			.material-download { flex-direction: column; text-align: center; }
		}
	</style>
</MainLayout>
