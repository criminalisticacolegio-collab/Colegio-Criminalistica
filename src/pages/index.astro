			border-color: var(--primary);
		}

		.image-wrapper {
			position: relative;
			height: 175px;
			overflow: hidden;
		}

		/* ── Ken Burns keyframes (5 variantes) ── */
		@keyframes kb1 { 0%{transform:scale(1) translate(0,0)}       100%{transform:scale(1.13) translate(-2%,-1.5%)} }
		@keyframes kb2 { 0%{transform:scale(1.11) translate(-1%,0)}  100%{transform:scale(1) translate(2%,1.5%)} }
		@keyframes kb3 { 0%{transform:scale(1) translate(2%,1%)}     100%{transform:scale(1.12) translate(-1.5%,-1%)} }
		@keyframes kb4 { 0%{transform:scale(1.1) translate(0,-1.5%)} 100%{transform:scale(1) translate(0,1.5%)} }
		@keyframes kb5 { 0%{transform:scale(1) translate(-1.5%,1%)}  100%{transform:scale(1.13) translate(2%,-1%)} }

		.image-wrapper img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			animation-timing-function: ease-in-out;
			animation-iteration-count: infinite;
			animation-direction: alternate;
			will-change: transform;
		}

		/* Cada tarjeta: animación y duración distintas */
		.grid-item:nth-child(5n+1) .image-wrapper img { animation-name: kb1; animation-duration: 11s; }
		.grid-item:nth-child(5n+2) .image-wrapper img { animation-name: kb2; animation-duration: 13s; }
		.grid-item:nth-child(5n+3) .image-wrapper img { animation-name: kb3; animation-duration: 9s;  }
		.grid-item:nth-child(5n+4) .image-wrapper img { animation-name: kb4; animation-duration: 14s; }
		.grid-item:nth-child(5n+0) .image-wrapper img { animation-name: kb5; animation-duration: 10s; }

		/* En hover: congela la animación donde estaba */
		.grid-item:hover .image-wrapper img { animation-play-state: paused; }

		.overlay {
