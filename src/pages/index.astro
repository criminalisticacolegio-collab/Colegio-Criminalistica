---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const home = await sanityClient.fetch(`*[_type == "homeConfig"][0]`).catch(() => null);

const noticiasDestacadas = await sanityClient.fetch(`
  *[_type == "noticiasConfig"][0]{
    "novedades": novedades[publicado != false && destacado == true] | order(fecha desc) [0..2] {
      titulo, bajada, fecha, categoria,
      "imagen": imagen.asset->url,
      link
    }
  }
`).then((d: any) => d?.novedades || []).catch(() => []);

const catColors: Record<string, string> = {
  Institucional: '#16a34a',
  Resolucion:    '#7c3aed',
  Capacitacion:  '#0891b2',
  Convocatoria:  '#d97706',
  General:       '#4b5563',
};
function formatFecha(dateStr: string) {
  if (!dateStr) return '';
  const [y, m, d] = dateStr.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const gridItems = [
	{ title: 'INSTITUCIONAL',          image: 'https://images.unsplash.com/photo-1568992687947-868a62a9f521?auto=format&fit=crop&w=800&q=80', desc: home?.descInstitucional     || 'Misión, visión y autoridades del Colegio.',                    link: '/institucional' },
	{ title: 'NUEVOS PROFESIONALES',   image: 'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=800&q=80', desc: home?.descNuevosProfesionales || 'Solicitud de matriculación y legajo virtual para aspirantes.', link: '/nuevos-profesionales' },
	{ title: 'PADRÓN OFICIAL',         image: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=800&q=80', desc: home?.descPadron            || 'Buscador oficial de profesionales habilitados.',               link: '/padron' },
	{ title: 'FORMACIÓN PROFESIONAL',   image: 'https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?auto=format&fit=crop&w=800&q=80', desc: home?.descCapacitacion      || 'Campus virtual, cursos y material de formación continua.',     link: '/capacitacion' },
	{ title: 'GESTIÓN',                image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80', desc: home?.descGestion           || 'Balances, memorias y rendición de cuentas.',                  link: '/gestion' },
	{ title: 'TRIBUNAL DE DISCIPLINA', image: 'https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&w=800&q=80', desc: home?.descTribunal          || 'Reglamento, resoluciones y normativa disciplinaria.',          link: '/disciplina' },
	{ title: 'NOTICIAS',               image: 'https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=800&q=80', desc: home?.descNoticias          || 'Novedades y comunicados institucionales.',                     link: '/noticias' },
	{ title: 'BIBLIOTECA LEGAL',       image: 'https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&w=800&q=80', desc: home?.descBiblioteca        || 'Legislación, protocolos y normativa vigente.',                 link: '/biblioteca' },
	{ title: 'MATRICULADOS',           image: 'https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=800&q=80', desc: home?.descMatriculados      || 'Mis pagos, mis certificados y datos profesionales.',           link: '/matriculados' },
	{ title: 'BOLSA DE TRABAJO',       image: 'https://images.unsplash.com/photo-1507679799987-c73779587ccf?auto=format&fit=crop&w=800&q=80', desc: home?.descBolsaTrabajo     || 'Profesionales disponibles y búsquedas activas.',              link: '/bolsa-trabajo' },
	{ title: 'PROYECTOS Y PROPUESTAS', image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=800&q=80', desc: home?.descProyectos        || 'Presentá iniciativas y propuestas institucionales.',           link: '/proyectos' },
	{ title: 'ARANCELES Y HONORARIOS', image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80', desc: home?.descAranceles         || 'Calculadora de honorarios periciales y tabla de aranceles sugeridos con generación de presupuesto PDF.', link: '/aranceles' },
];
---

<MainLayout title="Panel Principal">
	<section class="hero">
		<canvas id="hero-particles"></canvas>
		<div class="container hero-content">
			<p class="hero-sup">Bienvenido al portal oficial</p>
			<h1>Colegio de Profesionales en<br/>Ciencias Criminalísticas</h1>
			<p class="hero-slogan">CIENCIA Y JUSTICIA AL SERVICIO DE LA VERDAD</p>
			<p class="hero-sub">Provincia de Catamarca</p>
		</div>
	</section>

	{noticiasDestacadas.length > 0 && (
	<section class="idx-news-slider" id="idx-hero-slider" aria-label="Últimas novedades">

		<div class="idx-slider-track" id="idx-slider-track">
			{noticiasDestacadas.map((n: any, idx: number) => (
				<article class="idx-hs-slide" aria-hidden={idx !== 0 ? 'true' : 'false'}>
					{n.imagen
						? <img src={n.imagen + '?w=1200&auto=format'} alt={n.titulo} class="idx-hs-bg" loading={idx === 0 ? 'eager' : 'lazy'} />
						: <div class="idx-hs-fallback" style={`background: linear-gradient(135deg, ${catColors[n.categoria] || '#1b5e20'} 0%, #0a1a0d 100%)`}></div>
					}
					<div class="idx-hs-overlay"></div>
					<div class="idx-hs-content">
						<div class="idx-hs-meta">
							{n.categoria && <span class="idx-hs-badge" style={`background: ${catColors[n.categoria] || '#16a34a'}`}>{n.categoria}</span>}
							{n.fecha && <time class="idx-hs-date">{formatFecha(n.fecha)}</time>}
						</div>
						<h2 class="idx-hs-title">{n.titulo}</h2>
						{n.bajada && <p class="idx-hs-bajada">{n.bajada}</p>}
						<a href={n.link || '/noticias'} class="idx-hs-btn" target={n.link ? '_blank' : '_self'} rel={n.link ? 'noopener noreferrer' : undefined}>
							Leer más
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
						</a>
					</div>
				</article>
			))}
		</div>

		{noticiasDestacadas.length > 1 && (
			<>
				<button class="idx-sl-arrow idx-sl-prev" id="idx-slider-prev" aria-label="Novedad anterior">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="15 18 9 12 15 6"/></svg>
				</button>
				<button class="idx-sl-arrow idx-sl-next" id="idx-slider-next" aria-label="Siguiente novedad">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="9 18 15 12 9 6"/></svg>
				</button>
				<div class="idx-slider-dots">
					{noticiasDestacadas.map((_: any, i: number) => (
						<button class={`idx-sl-dot${i === 0 ? ' active' : ''}`} data-idx={i} aria-label={`Ir a novedad ${i + 1}`}></button>
					))}
				</div>
			</>
		)}

		<a href="/noticias" class="idx-ver-todas">Ver todas las novedades →</a>

	</section>
	)}

	<section class="grid-section">
		<canvas id="grid-particles"></canvas>
		<div class="container">
			<div class="main-grid">
				{gridItems.map(item => (
					<a href={item.link} class="grid-item">
						<div class="image-wrapper">
							<img src={item.image} alt={item.title} loading="lazy" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80'" />
							<div class="overlay"></div>
						</div>
						<div class="content">
							<h3>{item.title}</h3>
							<p>{item.desc}</p>
							<span class="action">Ingresar →</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<script>
		// ── Index novedades slider ──────────────────────────────
		const idxTrack   = document.getElementById('idx-slider-track') as HTMLElement | null;
		const idxSlides  = document.querySelectorAll<HTMLElement>('.idx-hs-slide');
		const idxDots    = document.querySelectorAll<HTMLButtonElement>('.idx-sl-dot');
		const idxPrev    = document.getElementById('idx-slider-prev') as HTMLButtonElement | null;
		const idxNext    = document.getElementById('idx-slider-next') as HTMLButtonElement | null;
		const idxSlider  = document.getElementById('idx-hero-slider');

		if (idxTrack && idxSlides.length > 1) {
			let idxCurrent = 0;
			let idxTimer: ReturnType<typeof setInterval> | null = null;

			function idxGoTo(idx: number) {
				idxCurrent = ((idx % idxSlides.length) + idxSlides.length) % idxSlides.length;
				idxTrack!.style.transform = `translateX(-${idxCurrent * 100}%)`;
				idxSlides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== idxCurrent)));
				idxDots.forEach((d, i) => d.classList.toggle('active', i === idxCurrent));
			}

			function idxStartAuto() {
				if (idxTimer) clearInterval(idxTimer);
				idxTimer = setInterval(() => idxGoTo(idxCurrent + 1), 5500);
			}

			idxPrev?.addEventListener('click', () => { idxGoTo(idxCurrent - 1); idxStartAuto(); });
			idxNext?.addEventListener('click', () => { idxGoTo(idxCurrent + 1); idxStartAuto(); });
			idxDots.forEach((dot, i) => dot.addEventListener('click', () => { idxGoTo(i); idxStartAuto(); }));

			idxSlider?.addEventListener('mouseenter', () => { if (idxTimer) clearInterval(idxTimer); });
			idxSlider?.addEventListener('mouseleave', idxStartAuto);

			let idxTx = 0;
			idxSlider?.addEventListener('touchstart', (e) => { idxTx = (e as TouchEvent).touches[0].clientX; }, { passive: true });
			idxSlider?.addEventListener('touchend', (e) => {
				const dx = (e as TouchEvent).changedTouches[0].clientX - idxTx;
				if (Math.abs(dx) > 48) { idxGoTo(dx < 0 ? idxCurrent + 1 : idxCurrent - 1); idxStartAuto(); }
			}, { passive: true });

			idxStartAuto();
		}
	</script>

	<script>
		// ── Hero particles ──────────────────────────────────────
		const canvas = document.getElementById('hero-particles') as HTMLCanvasElement;
		if (!canvas) throw new Error('no canvas');
		const ctx = canvas.getContext('2d')!;

		function resize() {
			canvas.width  = canvas.offsetWidth;
			canvas.height = canvas.offsetHeight;
		}
		resize();
		window.addEventListener('resize', resize);

		const COUNT = 55;
		type Particle = { x: number; y: number; r: number; vx: number; vy: number; alpha: number; alphaDir: number; };

		const particles: Particle[] = Array.from({ length: COUNT }, () => ({
			x: Math.random() * canvas.width,
			y: Math.random() * canvas.height,
			r: 1 + Math.random() * 2.5,
			vx: (Math.random() - 0.5) * 0.4,
			vy: -0.3 - Math.random() * 0.5,
			alpha: Math.random(),
			alphaDir: Math.random() > 0.5 ? 1 : -1,
		}));

		function tick() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);

			for (const p of particles) {
				p.x += p.vx;
				p.y += p.vy;
				p.alpha += 0.008 * p.alphaDir;
				if (p.alpha >= 1) { p.alpha = 1; p.alphaDir = -1; }
				if (p.alpha <= 0) { p.alpha = 0; p.alphaDir = 1; }

				if (p.y < -10) {
					p.y = canvas.height + 10;
					p.x = Math.random() * canvas.width;
				}
				if (p.x < -10) p.x = canvas.width + 10;
				if (p.x > canvas.width + 10) p.x = -10;

				ctx.beginPath();
				ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
				ctx.fillStyle = `rgba(200, 210, 220, ${p.alpha * 0.65})`;
				ctx.fill();
			}

			requestAnimationFrame(tick);
		}
		tick();

		// ── Grid sparkle particles (plata) ─────────────────────
		const gCanvas = document.getElementById('grid-particles') as HTMLCanvasElement;
		if (gCanvas) {
			const gCtx = gCanvas.getContext('2d')!;

			function resizeGrid() {
				gCanvas.width  = gCanvas.offsetWidth;
				gCanvas.height = gCanvas.offsetHeight;
			}
			resizeGrid();
			window.addEventListener('resize', resizeGrid);

			type GridParticle = { x: number; y: number; r: number; alpha: number; alphaDir: number; speed: number; isStar: boolean; };

			const gParticles: GridParticle[] = [
				// Puntos plateados de fondo
				...Array.from({ length: 80 }, () => ({
					x: Math.random() * gCanvas.width,
					y: Math.random() * gCanvas.height,
					r: 0.4 + Math.random() * 1.8,
					alpha: Math.random(),
					alphaDir: Math.random() > 0.5 ? 1 : -1,
					speed: 0.003 + Math.random() * 0.007,
					isStar: false,
				})),
				// Destellos en cruz de 4 puntas (efecto plata)
				...Array.from({ length: 50 }, () => ({
					x: Math.random() * gCanvas.width,
					y: Math.random() * gCanvas.height,
					r: 1.8 + Math.random() * 3.5,
					alpha: Math.random() * 0.55,
					alphaDir: Math.random() > 0.5 ? 1 : -1,
					speed: 0.006 + Math.random() * 0.013,
					isStar: true,
				})),
			];

			function drawSparkle(x: number, y: number, r: number, alpha: number) {
				const len = r * 2.6;
				const diag = len * 0.52;
				gCtx.save();
				gCtx.strokeStyle = `rgba(80, 140, 100, ${alpha * 0.7})`;
				gCtx.lineWidth = 0.75;
				gCtx.beginPath();
				// Cruz principal
				gCtx.moveTo(x, y - len); gCtx.lineTo(x, y + len);
				gCtx.moveTo(x - len, y); gCtx.lineTo(x + len, y);
				// Diagonales más cortas
				gCtx.moveTo(x - diag, y - diag); gCtx.lineTo(x + diag, y + diag);
				gCtx.moveTo(x + diag, y - diag); gCtx.lineTo(x - diag, y + diag);
				gCtx.stroke();
				// Núcleo con glow radial
				const g = gCtx.createRadialGradient(x, y, 0, x, y, r * 1.4);
				g.addColorStop(0, `rgba(140, 210, 160, ${alpha * 0.9})`);
				g.addColorStop(1, `rgba(80, 160, 100, 0)`);
				gCtx.beginPath();
				gCtx.arc(x, y, r * 1.4, 0, Math.PI * 2);
				gCtx.fillStyle = g;
				gCtx.fill();
				gCtx.restore();
			}

			function tickGrid() {
				gCtx.clearRect(0, 0, gCanvas.width, gCanvas.height);
				for (const p of gParticles) {
					p.alpha += p.speed * p.alphaDir;
					if (p.alpha >= 1) { p.alpha = 1; p.alphaDir = -1; }
					if (p.alpha <= 0) { p.alpha = 0; p.alphaDir = 1; }

					if (p.isStar) {
						drawSparkle(p.x, p.y, p.r, p.alpha);
					} else {
						gCtx.beginPath();
						gCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
						gCtx.fillStyle = `rgba(100, 160, 120, ${p.alpha * 0.55})`;
						gCtx.fill();
					}
				}
				requestAnimationFrame(tickGrid);
			}
			tickGrid();
		}
	</script>

	<!-- Zoom 125% + fondo puntillado solo en el index -->
	<style is:global>
		@media (min-width: 1100px) {
			html { zoom: 1.25; }
			/* Overriding .container so it scales with the viewport at any zoom level */
			.container {
				max-width: min(1500px, 94vw) !important;
			}
		}
		body {
			background-color: #f0f5f1 !important;
			background-image: radial-gradient(circle, rgba(27,94,32,0.08) 1.5px, transparent 1.5px) !important;
			background-size: 28px 28px !important;
			animation: none !important;
			background-attachment: scroll !important;
		}
		body::before { display: none !important; }
	</style>

	<style>
		/* ── HERO ─────────────────────────────────── */
		.hero {
			position: relative;
			padding: 6rem 0 5rem;
			background: linear-gradient(160deg, #041408 0%, #0a2810 50%, #1b5e20 100%);
			text-align: center;
			overflow: hidden;
		}

		#hero-particles {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			pointer-events: none;
		}

		.hero-content {
			position: relative;
			z-index: 1;
		}

		.hero-sup {
			font-size: 0.8rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.2em;
			color: rgba(255,255,255,0.5);
			margin-bottom: 1.25rem;
		}

		.hero-content h1 {
			font-family: 'Outfit', sans-serif;
			font-size: clamp(2rem, 5vw, 3.5rem);
			font-weight: 700;
			color: #ffffff;
			line-height: 1.15;
			margin-bottom: 1.5rem;
			max-width: 820px;
			margin-left: auto;
			margin-right: auto;
		}

		.hero-slogan {
			font-family: 'Outfit', sans-serif;
			font-size: clamp(0.9rem, 2.5vw, 1.2rem);
			font-weight: 800;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: #4ade80;
			margin-bottom: 1rem;
		}

		.hero-sub {
			font-size: 0.9rem;
			color: rgba(255,255,255,0.45);
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}

		/* ── NOVEDADES SLIDER (index) ─────────────── */
		.idx-news-slider {
			position: relative;
			width: 100%;
			height: 60vh;
			min-height: 420px;
			max-height: 680px;
			overflow: hidden;
			background: #0a1a0d;
		}

		.idx-slider-track {
			display: flex;
			height: 100%;
			transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
			will-change: transform;
		}

		.idx-hs-slide {
			position: relative;
			min-width: 100%;
			height: 100%;
			flex-shrink: 0;
			overflow: hidden;
		}

		.idx-hs-bg {
			position: absolute; inset: 0;
			width: 100%; height: 100%;
			object-fit: cover;
			object-position: center top;
		}

		.idx-hs-fallback { position: absolute; inset: 0; }

		.idx-hs-overlay {
			position: absolute; inset: 0;
			background: linear-gradient(
				105deg,
				rgba(0,0,0,0.88) 0%,
				rgba(0,0,0,0.68) 38%,
				rgba(0,0,0,0.22) 65%,
				rgba(0,0,0,0.02) 100%
			);
		}

		.idx-hs-content {
			position: absolute;
			left: clamp(1.5rem, 8vw, 7rem);
			top: 50%;
			transform: translateY(-50%);
			max-width: min(580px, 58vw);
			color: #fff;
			z-index: 2;
		}

		.idx-hs-meta {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			margin-bottom: 1rem;
			flex-wrap: wrap;
		}

		.idx-hs-badge {
			display: inline-block;
			padding: 0.25rem 0.75rem;
			border-radius: 20px;
			font-size: 0.68rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.09em;
			color: #fff;
		}

		.idx-hs-date {
			font-size: 0.78rem;
			color: rgba(255,255,255,0.62);
		}

		.idx-hs-title {
			font-size: clamp(1.4rem, 3.2vw, 2.4rem);
			font-weight: 700;
			line-height: 1.2;
			margin: 0 0 0.85rem;
			color: #fff;
			text-shadow: 0 2px 12px rgba(0,0,0,0.4);
		}

		.idx-hs-bajada {
			font-size: clamp(0.85rem, 1.3vw, 1rem);
			line-height: 1.6;
			color: rgba(255,255,255,0.78);
			margin-bottom: 1.5rem;
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.idx-hs-btn {
			display: inline-flex;
			align-items: center;
			gap: 0.45rem;
			padding: 0.6rem 1.3rem;
			border-radius: 7px;
			font-size: 0.86rem;
			font-weight: 600;
			text-decoration: none;
			background: var(--primary, #1a5c2a);
			color: #fff;
			border: 2px solid var(--primary, #1a5c2a);
			transition: all 0.2s ease;
			white-space: nowrap;
		}
		.idx-hs-btn:hover {
			background: transparent;
			color: #fff;
		}

		/* Flechas */
		.idx-sl-arrow {
			position: absolute;
			top: 50%;
			transform: translateY(-50%);
			z-index: 10;
			width: 44px; height: 44px;
			border-radius: 50%;
			border: 2px solid rgba(255,255,255,0.35);
			background: rgba(0,0,0,0.30);
			color: #fff;
			display: flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			transition: all 0.2s ease;
			backdrop-filter: blur(6px);
		}
		.idx-sl-arrow:hover {
			background: rgba(0,0,0,0.60);
			border-color: #fff;
		}
		.idx-sl-prev { left: 1.25rem; }
		.idx-sl-next { right: 1.25rem; }

		/* Puntos */
		.idx-slider-dots {
			position: absolute;
			bottom: 3.4rem;
			left: 50%;
			transform: translateX(-50%);
			display: flex;
