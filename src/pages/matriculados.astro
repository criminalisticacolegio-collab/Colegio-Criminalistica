  // ── Modal contactar administración ───────────────────────
  function setupModalContacto(mesesDetalle: any[], mat: any, email: string) {
    const btnAbrir   = document.getElementById('btn-contactar-admin') as HTMLButtonElement;
    const modal      = document.getElementById('modal-contacto-admin')!;
    const btnCerrar  = document.getElementById('btn-cerrar-modal') as HTMLButtonElement;
    const btnCancelar = document.getElementById('btn-cancelar-modal') as HTMLButtonElement;
    const btnEnviar  = document.getElementById('btn-enviar-contacto') as HTMLButtonElement;
    const fileInput  = document.getElementById('modal-comprobante') as HTMLInputElement;
    const uploadArea = document.getElementById('upload-area')!;
    const uploadFilename = document.getElementById('upload-filename')!;
    const uploadHint = uploadArea.querySelector('.upload-hint') as HTMLElement;
    const errorEl   = document.getElementById('modal-error')!;
    const successEl = document.getElementById('modal-success')!;

    const cerrarModal = () => {
      hide(modal);
      errorEl.classList.add('hidden');
      successEl.classList.add('hidden');
    };

    btnAbrir?.addEventListener('click', () => show(modal));
    btnCerrar?.addEventListener('click', cerrarModal);
    btnCancelar?.addEventListener('click', cerrarModal);
    modal?.addEventListener('click', (e) => { if (e.target === modal) cerrarModal(); });

    // Mostrar nombre de archivo seleccionado
    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) {
        uploadHint.classList.add('hidden');
        uploadFilename.textContent = `📎 ${file.name}`;
        uploadFilename.classList.remove('hidden');
      } else {
        uploadHint.classList.remove('hidden');
        uploadFilename.classList.add('hidden');
      }
    });

    btnEnviar?.addEventListener('click', async () => {
      const mensaje = (document.getElementById('modal-mensaje') as HTMLTextAreaElement).value.trim()
        || 'Solicito información para regularizar mis cuotas pendientes.';

      errorEl.classList.add('hidden');
      successEl.classList.add('hidden');
      btnEnviar.disabled = true;
      btnEnviar.textContent = 'Enviando...';

      let comprobanteUrl = '';

      // Si hay comprobante, subirlo como base64 — el servidor lo menciona en el email
      const file = fileInput?.files?.[0];
      if (file) {
        const reader = new FileReader();
        comprobanteUrl = await new Promise<string>((resolve) => {
          reader.onload = () => resolve(`[Archivo adjunto: ${file.name}]`);
          reader.readAsDataURL(file);
        });
      }

      try {
        const res = await fetch('/api/notificar-mora', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombreCompleto: mat.nombreCompleto,
            numeroMatricula: mat.numeroMatricula,
            email,
            mesesPendientes: mesesDetalle,
            mensaje,
            comprobanteUrl: file ? `Comprobante adjunto por el matriculado: ${file.name} (enviado desde el área privada)` : '',
          }),
        });
        const data = await res.json();
        if (!res.ok || data.error) {
          errorEl.textContent = data.error || 'No se pudo enviar. Intentá de nuevo.';
          errorEl.classList.remove('hidden');
        } else {
          successEl.textContent = `✅ Tu solicitud fue enviada. La administración te contactará a la brevedad al email ${email}.`;
          successEl.classList.remove('hidden');
          btnEnviar.textContent = 'Enviado ✓';
        }
      } catch {
        errorEl.textContent = 'Error de conexión. Verificá tu internet e intentá de nuevo.';
        errorEl.classList.remove('hidden');
        btnEnviar.disabled = false;
        btnEnviar.textContent = 'Enviar solicitud';
      }
    });
  }

  // ── Historial Sanity — tabla 12 meses ────────────────────
  const MESES_ORDEN = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

  function cargarHistorialSanity(historial: any[]) {
    const cont = document.getElementById('historial-container')!;
    const tablaMesesWrap = document.getElementById('tabla-meses-wrap')!;
    const selectorWrap   = document.getElementById('selector-anio-wrap')!;
    const resumenAnual   = document.getElementById('resumen-anual')!;

    if (!historial || historial.length === 0) {
      cont.innerHTML = '<p class="hist-empty">Sin cuotas registradas aún.</p>';
      return;
    }

    hide(cont);

    // Obtener años disponibles
    const aniosSet = new Set<number>(historial.map((h: any) => h.anio));
    const anios = Array.from(aniosSet).sort((a, b) => b - a);
    const anioActual = new Date().getFullYear();
    let anioSeleccionado = anios.includes(anioActual) ? anioActual : anios[0];

    // Poblar selector de año
    const selector = document.getElementById('selector-anio') as HTMLSelectElement;
    anios.forEach(a => {
      const opt = document.createElement('option');
      opt.value = String(a);
      opt.textContent = String(a);
      if (a === anioSeleccionado) opt.selected = true;
      selector.appendChild(opt);
    });

    show(selectorWrap);
    show(tablaMesesWrap);
    show(resumenAnual);

    const renderTabla = (anio: number) => {
      const tbody = document.getElementById('tabla-meses-body')!;
      const mesesDelAnio = historial.filter((h: any) => h.anio === anio);

      // Construir mapa mes → dato
      const mapaEstados: Record<string, any> = {};
      mesesDelAnio.forEach((h: any) => { mapaEstados[h.mes] = h; });

      const rows = MESES_ORDEN.map(mes => {
        const dato = mapaEstados[mes];
        if (!dato) {
          // Mes sin registro
          return `<tr class="fila-sin-dato">
            <td>${mes}</td>
            <td><span class="badge-mes badge-sin-dato">—</span></td>
            <td>—</td><td>—</td>
          </tr>`;
        }
        const esPagado = dato.estado === 'pagado';
        const fecha = dato.fechaPago
          ? new Date(dato.fechaPago).toLocaleDateString('es-AR', { day:'2-digit', month:'2-digit', year:'numeric' })
          : '—';
        const monto = dato.montoAbonado ? `$${Number(dato.montoAbonado).toLocaleString('es-AR')}` : '—';
        const badge = esPagado
          ? `<span class="badge-mes badge-pagado">✅ PAGADO</span>`
          : `<span class="badge-mes badge-pendiente">⏳ PENDIENTE</span>`;
        return `<tr>
          <td>${mes}</td>
          <td>${badge}</td>
          <td>${fecha}</td>
          <td>${monto}</td>
        </tr>`;
      }).join('');

      tbody.innerHTML = rows;

      // Actualizar resumen
      const pagas = mesesDelAnio.filter((h: any) => h.estado === 'pagado').length;
      const pendientes = mesesDelAnio.filter((h: any) => h.estado === 'pendiente').length;
      const badgeEstado = document.getElementById('badge-estado') as HTMLElement;
      const estadoGral = pendientes === 0 ? 'Al día ✅' : pendientes >= 3 ? 'Suspendida 🔴' : pendientes === 2 ? 'En mora 🔶' : 'Con pendiente ⚠️';

      document.getElementById('resumen-pagas')!.textContent = `${pagas}/12 pagas`;
      document.getElementById('resumen-pendientes')!.textContent = `${pendientes} pendiente${pendientes !== 1 ? 's' : ''}`;
      document.getElementById('resumen-estado-gral')!.textContent = estadoGral;
    };

    renderTabla(anioSeleccionado);

    selector.addEventListener('change', () => {
      renderTabla(Number(selector.value));
    });
  }

  // ── Pagos ─────────────────────────────────────────────────
  function setupPagos(email: string, linkCuota: string, linkAnual: string) {
    const handlePay = async (amount: number, title: string, btn: HTMLButtonElement, linkDirecto: string) => {
      const orig = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Procesando...';

      // Si hay un enlace directo cargado en Sanity, usarlo sin pasar por la API
      if (linkDirecto) {
        window.location.href = linkDirecto;
        return;
      }

      // Fallback: generar preferencia vía API de MercadoPago
      try {
        const res = await fetch('/api/create-preference', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amount, email, title }),
        });
        const data = await res.json();
        if (!res.ok || !data.init_point) {
          alert(data.error || 'No se pudo iniciar el pago. Contactá al Colegio.');
          btn.disabled = false;
          btn.textContent = orig!;
          return;
        }
        window.location.href = data.init_point;
      } catch {
        alert('Error de conexión. Verificá tu internet e intentá de nuevo.');
        btn.disabled = false;
        btn.textContent = orig!;
      }
    };

    document.getElementById('btn-pagar-cuota')?.addEventListener('click', function () {
      handlePay(valorCuota, 'Cuota Social Colegio', this as HTMLButtonElement, linkCuota);
    });
    document.getElementById('btn-pagar-anual')?.addEventListener('click', function () {
      handlePay(valorAnual, 'Matrícula Anual Colegio', this as HTMLButtonElement, linkAnual);
    });
  }

