  btnResetSubmit?.addEventListener('click', async () => {
    const email = resetEmailInput.value.trim();
    if (!email) {
      resetError.textContent = 'Ingresá tu email.';
      resetError.classList.remove('hidden');
      return;
    }

    resetError.classList.add('hidden');
    resetSuccess.classList.add('hidden');
    resetNotPadron.classList.add('hidden');
    btnResetSubmit.disabled = true;
    btnResetSubmit.textContent = 'Verificando...';

    if (!auth) {
      resetError.textContent = 'El sistema de autenticación no está disponible. Contactá a Secretaría.';
      resetError.classList.remove('hidden');
      btnResetSubmit.disabled = false;
      btnResetSubmit.textContent = 'Enviar instrucciones';
      return;
    }

    try {
      btnResetSubmit.textContent = 'Enviando...';

      const res = await fetch('/api/send-reset-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();

      if (data.redirect) {
        window.location.href = data.redirect;
        return;
      } else if (data.notInPadron) {
        resetNotPadron.classList.remove('hidden');
      } else if (!res.ok || data.error) {
        resetError.textContent = data.error || 'No se pudo enviar el email. Intentá de nuevo.';
        resetError.classList.remove('hidden');
      } else {
        resetSuccess.textContent = `Te enviamos un email a ${email} con el enlace para crear o recuperar tu contraseña. Revisá también la carpeta de spam.`;
        resetSuccess.classList.remove('hidden');
        resetEmailInput.value = '';
      }
    } catch (err: any) {
      console.error('Reset error:', err);
      resetError.textContent = 'Error de conexión. Verificá tu internet e intentá de nuevo.';
      resetError.classList.remove('hidden');
    } finally {
      resettingPassword = false;
      btnResetSubmit.disabled = false;
      btnResetSubmit.textContent = 'Enviar instrucciones';
    }
  });

