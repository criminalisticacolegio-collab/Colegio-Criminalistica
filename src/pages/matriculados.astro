---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

const [config, institucional, tribunal] = await Promise.all([
  sanityClient.fetch(`*[_type == "configuracionCobros"][0]`),
  sanityClient.fetch(`*[_type == "institucionalConfig"][0]{ presidente_nombre, presidente_especialidad }`),
  sanityClient.fetch(`*[_type == "tribunalConfig"][0]{ presidenteTrib_nombre, presidenteTrib_especialidad }`),
]);
const valorCuota   = config?.valorCuotaMensual   || 0;
const valorAnual   = config?.valorMatriculaAnual  || 0;
const promoActiva  = config?.promocionAnualActiva || false;
const linkCuota    = config?.enlaceCuotaMensual   || '';
const linkAnual    = config?.enlacePagoAnual      || '';
const pteColegio       = institucional?.presidente_nombre       || 'Presidente';
const pteColegioCargo  = institucional?.presidente_especialidad || 'Presidente · CPC CTM';
const pteTribunal      = tribunal?.presidenteTrib_nombre        || 'Presidente del Tribunal';
const pteTribunalCargo = tribunal?.presidenteTrib_especialidad  || 'Presidente del Tribunal de Ética · CPC CTM';
---

<MainLayout title="Matriculados">
  <!-- Datos de config pasados al cliente -->
  <div id="cfg" data-cuota={valorCuota} data-anual={valorAnual} data-promo={promoActiva ? 'true' : 'false'} data-link-cuota={linkCuota} data-link-anual={linkAnual} class="hidden"></div>
  <div id="firmas"
    data-pte-colegio={pteColegio}
    data-pte-colegio-cargo={pteColegioCargo}
    data-pte-tribunal={pteTribunal}
    data-pte-tribunal-cargo={pteTribunalCargo}
    class="hidden"></div>

  <!-- Estado: cargando -->
  <div id="state-loading" class="auth-loading">
    <div class="spinner-ring"></div>
    <p>Verificando credenciales...</p>
  </div>

  <!-- Estado: no autenticado -->
  <div id="state-login" class="auth-gate hidden">
    <div class="gate-card glass">
      <div class="gate-icon">🔒</div>
      <h1>Área de Matriculados</h1>
      <p>Esta sección es exclusiva para profesionales colegiados. Iniciá sesión para acceder a tus pagos y certificados.</p>
      <form id="gate-form" class="gate-form">
        <div class="form-group">
          <label>Correo Electrónico</label>
          <input type="email" id="gate-email" placeholder="tu@email.com" required />
        </div>
        <div class="form-group">
          <label>Contraseña</label>
          <input type="password" id="gate-password" placeholder="••••••••" required />
        </div>
        <div id="gate-error" class="gate-error hidden">Credenciales incorrectas. Verificá tus datos.</div>
        <button type="submit" id="gate-btn" class="btn-login-gate">Ingresar</button>
      </form>

      <!-- Olvidé contraseña / Primera vez -->
      <div id="reset-section" class="reset-section">
        <button type="button" id="btn-forgot" class="btn-forgot">
          ¿Olvidaste tu contraseña o es tu primera vez?
        </button>
        <!-- Formulario de recuperación (oculto por defecto) -->
        <div id="reset-form-wrap" class="reset-form-wrap hidden">
          <div class="reset-form-inner">
            <input type="email" id="reset-email" placeholder="Tu email registrado en el padrón" autocomplete="email" />
            <button type="button" id="btn-reset-submit" class="btn-reset-submit">
              Enviar instrucciones
            </button>
          </div>
          <p id="reset-error" class="reset-msg reset-msg-error hidden"></p>
          <p id="reset-success" class="reset-msg reset-msg-ok hidden"></p>
          <div id="reset-not-padron" class="reset-not-padron hidden">
            <p>Este email no está registrado en el Colegio.</p>
            <a href="/nuevos-profesionales" class="btn-matricularse">¿Querés matricularte? →</a>
          </div>
        </div>
      </div>

      <p class="gate-links">
        <a href="/nuevos-profesionales" class="gate-link">¿Aún no estás matriculado?</a>
      </p>
    </div>
  </div>

  <!-- Estado: no vinculado al padrón -->
  <div id="state-unlinked" class="auth-gate hidden">
    <div class="gate-card glass warning-card">
      <div class="gate-icon">⚠️</div>
      <h2>Email no vinculado al Padrón</h2>
      <p>Tu cuenta (<strong id="unlinked-email-text"></strong>) no está registrada en el Padrón Oficial del CPC CTM.</p>
      <p>Contactá a Secretaría para vincular tu legajo digital.</p>
      <div class="gate-actions">
        <button onclick="window.toggleContactDrawer()" class="btn-primary">Contactar Secretaría</button>
        <button id="btn-logout-unlinked" class="btn-outline">Cerrar Sesión</button>
      </div>
    </div>
  </div>

  <!-- Contenido principal -->
  <div id="main-content" class="container page-content hidden">
    <header class="account-header">
      <div class="header-info">
        <span class="section-label">Área Privada</span>
        <h1>Bienvenido/a, <span id="user-name">—</span></h1>
        <p>Matrícula N° <strong id="user-mat">—</strong> · <span id="user-estado-text" class="estado-inline">—</span></p>
      </div>
      <button id="btn-logout" class="btn-logout">Cerrar Sesión</button>
    </header>

    <!-- Banner: email no verificado -->
    <div id="banner-verify" class="banner-verify hidden">
      <span>⚠️</span>
      <p>Por favor verificá tu dirección de email para activar todas las funciones. Revisá tu bandeja de entrada.</p>
      <button id="btn-resend-verify" class="btn-resend-verify">Reenviar email</button>
    </div>

    <!-- ══ BANNERS DE MORA ══ -->
    <!-- 0 meses pendientes -->
    <div id="banner-al-dia" class="banner-mora banner-verde hidden">
      <span class="banner-icon">✅</span>
      <div class="banner-body">
        <p class="banner-title">Al día</p>
        <p class="banner-msg">Tu situación de cuotas está al corriente.</p>
      </div>
      <button id="btn-pagar-mes" class="btn-mora-pay">Pagar cuota del mes</button>
    </div>

    <!-- 1 mes pendiente -->
    <div id="banner-1mes" class="banner-mora banner-amarillo hidden">
      <span class="banner-icon">⚠️</span>
      <div class="banner-body">
        <p class="banner-title">Tenés 1 cuota pendiente</p>
        <p class="banner-msg">Regularizá tu situación para evitar inconvenientes.</p>
      </div>
      <button id="btn-pagar-mora-1" class="btn-mora-pay">Pagar ahora</button>
    </div>

    <!-- 2 meses pendientes -->
    <div id="banner-2meses" class="banner-mora banner-naranja hidden">
      <span class="banner-icon">🔶</span>
      <div class="banner-body">
        <p class="banner-title">Tenés 2 cuotas pendientes</p>
        <p class="banner-msg">Si no regularizás, tu matrícula puede ser suspendida.</p>
      </div>
      <button id="btn-pagar-mora-2" class="btn-mora-pay btn-mora-urgente">Pagar ahora</button>
    </div>

    <!-- 3+ meses → suspendido -->
    <div id="banner-suspendido" class="banner-mora banner-rojo hidden">
      <span class="banner-icon">🔴</span>
      <div class="banner-body">
        <p class="banner-title">Tu matrícula ha sido SUSPENDIDA</p>
        <p class="banner-msg">Falta de pago de 3 o más cuotas consecutivas. Para regularizar tu situación contactá a la administración del Colegio.</p>
      </div>
      <button id="btn-contactar-admin" class="btn-mora-contacto">Contactar administración</button>
    </div>

    <!-- Alerta si no está activo (estado distinto de Activo, no mora) -->
    <div id="alert-inactive" class="alert-inactive hidden">
      <span>⚠️</span>
      <p>Tu matrícula no está activa. No podés descargar certificados. Regularizá tu situación contactando al Colegio.</p>
      <button onclick="window.toggleContactDrawer()" class="btn-contact-inline">Contactar</button>
    </div>

    <!-- ══ MODAL CONTACTAR ADMINISTRACIÓN ══ -->
    <div id="modal-contacto-admin" class="modal-overlay hidden">
      <div class="modal-card glass">
        <div class="modal-header">
          <h3>Contactar Administración</h3>
          <button id="btn-cerrar-modal" class="btn-modal-close">✕</button>
        </div>
        <p class="modal-desc">Enviá tu solicitud de regularización. La administración te contactará al email registrado.</p>
        <div class="modal-body">
          <label class="modal-label">Mensaje</label>
          <textarea id="modal-mensaje" class="modal-textarea" rows="4">Solicito información para regularizar mis cuotas pendientes.</textarea>
          <label class="modal-label">Adjuntar comprobante de pago (opcional)</label>
          <div class="upload-area" id="upload-area">
            <input type="file" id="modal-comprobante" accept=".pdf,.jpg,.jpeg,.png" class="upload-input" />
            <p class="upload-hint">📎 PDF, JPG o PNG — hacé clic o arrastrá el archivo aquí</p>
            <p id="upload-filename" class="upload-filename hidden"></p>
          </div>
          <div id="modal-error" class="modal-msg modal-error hidden"></div>
          <div id="modal-success" class="modal-msg modal-success hidden"></div>
        </div>
        <div class="modal-footer">
          <button id="btn-enviar-contacto" class="btn-modal-send">Enviar solicitud</button>
          <button id="btn-cancelar-modal" class="btn-modal-cancel">Cancelar</button>
        </div>
      </div>
    </div>

    <div class="two-col-layout">

      <!-- ══ COLUMNA IZQUIERDA: MIS PAGOS ══ -->
      <section class="col-left">
        <h2 class="col-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Mis Pagos
        </h2>

        <!-- Card: cuota mensual -->
        <div class="pay-card glass">
          <div class="pay-card-header">
            <div class="pay-icon blue">💳</div>
            <div>
              <h3>Cuota Mensual</h3>
              <p class="pay-desc">Aporte social mensual al Colegio</p>
            </div>
          </div>
          <div class="pay-amount" id="display-cuota">
            ${valorCuota.toLocaleString('es-AR')}
          </div>
          <button id="btn-pagar-cuota" class="btn-pay">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Pagar ahora
          </button>
        </div>

        <!-- Card: matrícula anual -->
        <div class="pay-card glass">
          <div class="pay-card-header">
            <div class="pay-icon green">🏅</div>
            <div>
              <h3>
                Matrícula Anual
                {promoActiva && <span class="promo-badge">PROMO ACTIVA</span>}
              </h3>
              <p class="pay-desc">Renovación anual de habilitación profesional</p>
            </div>
          </div>
          <div class="pay-amount" id="display-anual">
            ${valorAnual.toLocaleString('es-AR')}
          </div>
          <button id="btn-pagar-anual" class="btn-pay btn-pay-green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Pagar matrícula
          </button>
        </div>

        <!-- Card: historial de cuotas con selector de año -->
        <div class="pay-card glass">
          <div class="pay-card-header">
            <div class="pay-icon gray">📋</div>
            <div>
              <h3>Historial de Cuotas</h3>
              <p class="pay-desc">Estado mensual de tus pagos</p>
            </div>
            <span id="badge-estado" class="estado-badge al-dia">AL DÍA</span>
          </div>

          <!-- Resumen anual -->
          <div id="resumen-anual" class="resumen-anual hidden">
            <span id="resumen-pagas" class="resumen-item resumen-ok">—</span>
            <span id="resumen-pendientes" class="resumen-item resumen-warn">—</span>
            <span id="resumen-estado-gral" class="resumen-item">—</span>
          </div>

          <!-- Selector de año -->
          <div id="selector-anio-wrap" class="selector-anio-wrap hidden">
            <label class="selector-label">Año:</label>
            <select id="selector-anio" class="selector-anio"></select>
          </div>

          <!-- Tabla 12 meses -->
          <div id="tabla-meses-wrap" class="hidden">
            <table class="tabla-meses">
              <thead>
                <tr>
                  <th>Mes</th>
                  <th>Estado</th>
                  <th>Fecha pago</th>
                  <th>Monto</th>
                </tr>
              </thead>
              <tbody id="tabla-meses-body"></tbody>
            </table>
          </div>

          <div id="historial-container">
            <p class="hist-loading">Cargando historial...</p>
          </div>
        </div>
      </section>

      <!-- ══ COLUMNA DERECHA: MIS CERTIFICADOS ══ -->
      <section class="col-right">
        <h2 class="col-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Mis Certificados
        </h2>

        <!-- Constancia de Matrícula -->
        <div class="cert-card glass" id="cert-matricula">
          <div class="cert-header">
            <div class="cert-icon green-bg">📜</div>
            <div>
              <h3>Constancia de Matrícula Vigente</h3>
              <p class="cert-desc">Certifica tu habilitación como profesional activo del CPC CTM. Vigencia 30 días desde la emisión.</p>
            </div>
          </div>
          <div class="cert-use">
            <span class="use-label">Útil para:</span>
            licitaciones, concursos, peritos judiciales, convenios institucionales.
          </div>
          <button id="btn-cert-matricula" class="btn-cert" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar PDF
          </button>
        </div>

        <!-- Constancia de Ética -->
        <div class="cert-card glass" id="cert-etica">
          <div class="cert-header">
            <div class="cert-icon blue-bg">⚖️</div>
            <div>
              <h3>Constancia de Ética Profesional</h3>
              <p class="cert-desc">Certifica que no registrás sanciones disciplinarias vigentes ante el Tribunal del Colegio.</p>
            </div>
          </div>
          <div class="cert-use">
            <span class="use-label">Útil para:</span>
            concursos públicos, habilitaciones judiciales, contratos con organismos del Estado.
          </div>
          <button id="btn-cert-etica" class="btn-cert btn-cert-blue" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar PDF
          </button>
          <div id="etica-msg" class="cert-msg hidden"></div>
        </div>

        <p class="cert-note">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Los certificados están disponibles solo para matriculados con estado <strong>Activo</strong>.
        </p>
      </section>
    </div>
  </div>
</MainLayout>

<script>
  import { auth } from '../lib/firebase';
  import { signInWithEmailAndPassword, signOut, onAuthStateChanged, sendEmailVerification } from 'firebase/auth';
  import { createClient } from '@sanity/client';

  const sanity = createClient({
    projectId: '8q7vz6co', dataset: 'production', useCdn: false, apiVersion: '2023-05-03',
  });

  const cfg = document.getElementById('cfg')!;
  const valorCuota = Number(cfg.dataset.cuota) || 0;
  const valorAnual = Number(cfg.dataset.anual) || 0;
  const linkCuota  = cfg.dataset.linkCuota  || '';
  const linkAnual  = cfg.dataset.linkAnual  || '';

  const firmasEl = document.getElementById('firmas')!;
  const firmas = {
    pteColegio:       firmasEl.dataset.pteColegio       || 'Presidente',
    pteColegioCargo:  firmasEl.dataset.pteColegioCargo  || 'Presidente · CPC CTM',
    pteTribunal:      firmasEl.dataset.pteTribunal      || 'Presidente del Tribunal',
    pteTribunalCargo: firmasEl.dataset.pteTribunalCargo || 'Presidente del Tribunal de Ética · CPC CTM',
  };

  const stateLoading = document.getElementById('state-loading')!;
  const stateLogin   = document.getElementById('state-login')!;
  const stateUnlinked = document.getElementById('state-unlinked')!;
  const mainContent  = document.getElementById('main-content')!;

  function show(el: HTMLElement) { el.classList.remove('hidden'); }
  function hide(el: HTMLElement) { el.classList.add('hidden'); }

  async function getLogoBase64(): Promise<string | null> {
    try {
      const resp = await fetch('/LOGO-CENTRAL.jpg');
      if (!resp.ok) return null;
      const blob = await resp.blob();
      return await new Promise<string>((resolve, reject) => {
        const reader = new FileReader();
        reader.onloadend = () => resolve(reader.result as string);
        reader.onerror = reject;
        reader.readAsDataURL(blob);
      });
    } catch { return null; }
  }

  function drawPdfHeader(doc: any, logo: string | null) {
    doc.setFillColor(27, 94, 32);
    doc.rect(0, 0, 210, 50, 'F');
    if (logo) doc.addImage(logo, 'JPEG', 94, 5, 22, 22);
    doc.setTextColor(255, 255, 255);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(13);
    doc.text('COLEGIO DE PROFESIONALES EN CIENCIAS CRIMINALÍSTICAS', 105, 33, { align: 'center' });
    doc.setFontSize(9);
    doc.setFont('helvetica', 'normal');
    doc.text('PROVINCIA DE CATAMARCA', 105, 42, { align: 'center' });
  }

  function drawPdfFooter(doc: any, ctc: any) {
    const dir = ctc?.direccion || 'Sede Oficial — San Fernando del Valle de Catamarca';
    const parts = [ctc?.correo || 'criminalisticacolegio@gmail.com'];
    if (ctc?.telefono || ctc?.telefonoOficial) parts.push(ctc.telefono || ctc.telefonoOficial);
    doc.setFillColor(27, 94, 32);
    doc.rect(0, 275, 210, 22, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(7);
    doc.text(dir, 105, 283, { align: 'center' });
    doc.text(parts.join('  ·  '), 105, 291, { align: 'center' });
  }

  // Fallback: si Firebase no responde en 6s, mostrar login con aviso
  const authFallback = setTimeout(() => {
    hide(stateLoading);
    show(stateLogin);
    const errEl = document.getElementById('gate-error');
    if (errEl) {
      errEl.textContent = 'El sistema de autenticación no está disponible. Configurá las credenciales de Firebase.';
      errEl.classList.remove('hidden');
    }
  }, 6000);

  let resettingPassword = false;

  // ── Auth state ────────────────────────────────────────────
  if (!auth) {
    clearTimeout(authFallback);
    hide(stateLoading);
    show(stateLogin);
    const errEl = document.getElementById('gate-error');
    if (errEl) {
      errEl.textContent = 'Firebase no está configurado. Completá las credenciales en el archivo .env.';
      errEl.classList.remove('hidden');
    }
  } else {
  onAuthStateChanged(auth, async (user) => {
    if (resettingPassword) return;
    clearTimeout(authFallback);
    hide(stateLoading);
    if (!user) { show(stateLogin); return; }

    // Buscar matriculado en Sanity
    let mat: any = null;
    try {
      mat = await sanity.fetch(
        `*[_type == "matriculado" && lower(email) == lower($email)][0]{
          nombreCompleto, numeroMatricula, estado, email,
          especialidad->{ titulo }, jurisdiccion->{ titulo }
        }`,
        { email: user.email }
      );
    } catch (e) { console.error(e); }



    if (!mat) {
      (document.getElementById('unlinked-email-text') as HTMLElement).textContent = user.email || '';
      show(stateUnlinked);
      return;
    }

    // Mostrar contenido principal
    show(mainContent);

    // Banner si el email aún no está verificado
    if (!user.emailVerified) {
      const bannerVerify = document.getElementById('banner-verify')!;
      show(bannerVerify);
      const btnResend = document.getElementById('btn-resend-verify') as HTMLButtonElement;
      btnResend?.addEventListener('click', async () => {
        btnResend.disabled = true;
        btnResend.textContent = 'Enviando...';
        try {
          await sendEmailVerification(user);
          btnResend.textContent = '✓ Email enviado';
        } catch {
          btnResend.disabled = false;
          btnResend.textContent = 'Reenviar email';
        }
      });
    }

    (document.getElementById('user-name') as HTMLElement).textContent = mat.nombreCompleto || '—';
    (document.getElementById('user-mat') as HTMLElement).textContent = mat.numeroMatricula || '—';
    const estadoText = document.getElementById('user-estado-text') as HTMLElement;
    estadoText.textContent = mat.estado || '—';
    estadoText.className = `estado-inline ${mat.estado === 'Activo' ? 'activo' : 'inactivo'}`;

    // Verificar estado de pagos y cargar historial
    const pagoData = await verificarEstadoPagos(user);

    const estadoFinal = pagoData?.estado || mat.estado;
    const mesesPendConsec = pagoData?.mesesPendientesConsecutivos ?? 0;
    const historial: any[] = pagoData?.historialPagos || [];

    // Actualizar texto de estado si cambió (p.ej. suspendido automáticamente)
    if (estadoFinal !== mat.estado) {
      estadoText.textContent = estadoFinal;
      estadoText.className = `estado-inline ${estadoFinal === 'Activo' ? 'activo' : 'inactivo'}`;
    }

    const esActivo = estadoFinal === 'Activo';

    // Mostrar banner de mora según cantidad de meses
    mostrarBannerMora(mesesPendConsec, esActivo, linkCuota, pagoData?.mesesPendientes || [], mat, user.email!);

    if (!esActivo && estadoFinal !== 'Suspendido') {
      show(document.getElementById('alert-inactive')!);
    }

    // Habilitar/deshabilitar certificados
    const btnMat = document.getElementById('btn-cert-matricula') as HTMLButtonElement;
    const btnEtica = document.getElementById('btn-cert-etica') as HTMLButtonElement;
    if (esActivo) {
      btnMat.disabled = false;
      btnEtica.disabled = false;

      btnMat.addEventListener('click', async () => {
        btnMat.disabled = true;
        btnMat.textContent = 'Generando...';
        try {
          const tkn = await user.getIdToken();
          const res = await fetch('/api/pdf-certificado-matricula', {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${tkn}` },
          });
          if (!res.ok) {
