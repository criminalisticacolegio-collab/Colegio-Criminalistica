---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Pago Exitoso" showBack={false}>
	<div class="container success-page">
		<div class="success-card glass">
			<div class="success-header">
				<div class="success-badge">✅</div>
				<h1>¡Pago Procesado con Éxito!</h1>
				<p>Gracias por mantener tu matrícula al día. El comprobante ha sido generado correctamente.</p>
			</div>

			<div class="receipt-preview">
				<div class="receipt-item">
					<span>Estado:</span>
					<strong class="text-success">Aprobado</strong>
				</div>
				<div class="receipt-item">
					<span>Fecha:</span>
					<strong id="current-date"></strong>
				</div>
				<div class="receipt-item">
					<span>Referencia:</span>
					<strong id="payment-id">MP-XXXXXX</strong>
				</div>
			</div>

			<div class="action-buttons">
				<button id="download-receipt" class="btn-primary-large">
					<span>📥 Descargar Recibo (PDF)</span>
				</button>
				<a href="/estado-cuenta" class="btn-outline">Volver al Panel</a>
			</div>
		</div>
	</div>
</MainLayout>

<script>
	import { jsPDF } from "jspdf";
	import { auth } from '../lib/firebase';
	import { onAuthStateChanged } from 'firebase/auth';
	import { createClient } from '@sanity/client';

	const sanity = createClient({
		projectId: '8q7vz6co',
		dataset: 'production',
		useCdn: true,
		apiVersion: '2023-05-03'
	});

	const urlParams = new URLSearchParams(window.location.search);
	const paymentId = urlParams.get('payment_id') || 'N/A';
	const paymentIdEl = document.getElementById('payment-id');
	if (paymentIdEl) paymentIdEl.textContent = paymentId;

	const dateEl = document.getElementById('current-date');
	if (dateEl) dateEl.textContent = new Date().toLocaleDateString('es-AR');

	let userData: any = null;

	onAuthStateChanged(auth, async (user) => {
		if (user) {
			const email = user.email;
			const query = `*[_type == "matriculado" && email == $email][0]`;
			userData = await sanity.fetch(query, { email });
		}
	});

	document.getElementById('download-receipt')?.addEventListener('click', async () => {
		if (!userData) {
			alert('Cargando datos del profesional...');
			return;
		}

		// Obtener logo
		let logoData = '';
		try {
			const res = await fetch('/LOGO-CENTRAL.jpg');
			const blob = await res.blob();
			logoData = await new Promise<string>((resolve) => {
				const reader = new FileReader();
				reader.onload = (e) => resolve((e.target?.result as string) ?? '');
				reader.readAsDataURL(blob);
			});
		} catch { /* logo unavailable */ }

		const doc = new jsPDF();
		const fechaStr = new Date().toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' });

		// ── Encabezado ──
		doc.setFillColor(27, 94, 32);
		doc.rect(0, 0, 210, 40, 'F');

		if (logoData) {
			doc.addImage(logoData, 'JPEG', 6, 6, 26, 26);
		}

		doc.setTextColor(255, 255, 255);
		doc.setFont('helvetica', 'bold');
		doc.setFontSize(15);
		doc.text('COLEGIO DE PROFESIONALES EN CIENCIAS', 105, 13, { align: 'center' });
		doc.text('CRIMINALÍSTICAS DE CATAMARCA', 105, 21, { align: 'center' });
		doc.setFontSize(10);
		doc.setFont('helvetica', 'normal');
		doc.text('COMPROBANTE OFICIAL DE PAGO', 105, 32, { align: 'center' });

		// ── Separador ──
		doc.setDrawColor(27, 94, 32);
		doc.setLineWidth(0.5);
		doc.line(15, 48, 195, 48);

		// ── Datos ──
		const col1 = 15;
		const col2 = 80;
		let y = 58;
		const lineH = 9;

		const campo = (label: string, valor: string) => {
			doc.setFont('helvetica', 'bold');
			doc.setFontSize(10);
			doc.setTextColor(44, 62, 80);
			doc.text(label, col1, y);
			doc.setFont('helvetica', 'normal');
			doc.setTextColor(0, 0, 0);
			doc.text(valor, col2, y);
			y += lineH;
		};

		campo('Fecha de Emisión:', fechaStr);
		campo('N° de Operación MP:', paymentId);

		y += 4;
		doc.setDrawColor(200, 200, 200);
		doc.line(15, y, 195, y);
		y += 8;

		doc.setFont('helvetica', 'bold');
		doc.setFontSize(11);
		doc.setTextColor(27, 94, 32);
		doc.text('DATOS DEL PROFESIONAL', col1, y);
		y += lineH;

		campo('Nombre Completo:', userData.nombreCompleto || '');
		campo('N° de Matrícula:', userData.numeroMatricula || '');
		campo('Email:', userData.email || '');

		y += 4;
		doc.setDrawColor(200, 200, 200);
		doc.line(15, y, 195, y);
		y += 8;

		doc.setFont('helvetica', 'bold');
		doc.setFontSize(11);
		doc.setTextColor(27, 94, 32);
		doc.text('DETALLE DEL PAGO', col1, y);
		y += lineH;

		campo('Concepto:', 'Cuota Social / Matrícula Anual CPC CTM');
		campo('Método de Pago:', 'MercadoPago');
		campo('Estado:', 'APROBADO ✓');

		// ── Nota legal ──
		y += 10;
		doc.setFont('helvetica', 'italic');
		doc.setFontSize(8);
		doc.setTextColor(120, 120, 120);
		doc.text('Este comprobante es válido como recibo de pago. La acreditación definitiva', 105, y, { align: 'center' });
		doc.text('impactará en su legajo en un plazo de 24 horas hábiles.', 105, y + 5, { align: 'center' });

		// ── Pie de página ──
		doc.setFillColor(27, 94, 32);
		doc.rect(0, 282, 210, 15, 'F');
		doc.setTextColor(255, 255, 255);
		doc.setFont('helvetica', 'normal');
		doc.setFontSize(7);
		doc.text('criminalisticacolegio@gmail.com  |  San Fernando del Valle de Catamarca', 105, 291, { align: 'center' });

		doc.save(`Recibo_CPC_CTM_${userData.numeroMatricula || paymentId}.pdf`);
	});
</script>

<style>
	.success-page {
		min-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4rem 1rem;
	}

	.success-card {
		max-width: 500px;
		width: 100%;
		padding: 3rem;
		border-radius: var(--radius-lg);
		text-align: center;
		box-shadow: var(--shadow-lg);
		border: 2px solid #dcfce7;
	}

	.success-badge {
		width: 80px;
		height: 80px;
		background: #dcfce7;
		color: #166534;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.5rem;
		margin: 0 auto 2rem;
	}

	.success-header h1 {
		color: #166534;
		font-size: 1.8rem;
		margin-bottom: 1rem;
	}

	.success-header p {
		color: var(--text-light);
		margin-bottom: 2.5rem;
	}

	.receipt-preview {
		background: var(--gray-50);
		padding: 1.5rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--gray-200);
		margin-bottom: 2.5rem;
		text-align: left;
	}

	.receipt-item {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.75rem;
		font-size: 0.95rem;
	}

	.receipt-item strong {
		color: var(--accent);
	}

	.text-success { color: #166534; }

	.action-buttons {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.btn-primary-large {
		background: var(--primary);
		color: white;
		border: none;
		padding: 1.25rem;
		border-radius: var(--radius-md);
		font-weight: 700;
		font-size: 1.1rem;
		cursor: pointer;
		transition: var(--transition);
	}

	.btn-primary-large:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
	}

	.btn-outline {
		color: var(--primary);
		text-decoration: none;
		font-weight: 600;
		padding: 0.5rem;
	}
</style>
