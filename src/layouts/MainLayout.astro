---
import ContactDrawer from '../components/ContactDrawer.astro';

interface Props {
	title: string;
	showBack?: boolean;
}

const { title, showBack = false } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Colegio de Profesionales en Ciencias Criminalísticas de la Provincia de Catamarca" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | CPC CTM</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="main-header">
			<div class="container header-content">
				<div class="header-left">
					{showBack && (
						<button onclick="history.back()" class="back-btn" title="Volver a la página anterior">
							<span class="icon">←</span> Volver
						</button>
					)}
					<a href="/" class="logo">
						<img src="/logo.png" alt="CPC CTM Logo" class="logo-img" />
						<div class="logo-text">
							<span class="brand">Colegio de Profesionales en Ciencias Criminalísticas</span>
							<span class="sub-brand">Ciencia y Justicia</span>
						</div>
					</a>
				</div>
				<nav class="main-nav">
					<ul>
						<li><a href="/">Inicio</a></li>
						<li><a href="/institucional">Institucional</a></li>
						<li><a href="/padron">Padrón</a></li>
						<li><button onclick="window.toggleContactDrawer()" class="contact-trigger">Contacto</button></li>
					</ul>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="main-footer">
			<div class="container footer-grid">
				<div class="footer-brand">
					<div class="f-logo">
						<span class="f-icon">⚖️</span>
						<div class="f-text">
							<h3>CPC CTM</h3>
							<span>Catamarca</span>
						</div>
					</div>
					<p class="f-desc">Colegio de Profesionales en Ciencias Criminalísticas de la Provincia de Catamarca. Comprometidos con la verdad y la excelencia técnica.</p>
				</div>
				
				<div class="footer-contact">
					<h4>Contacto Institucional</h4>
					<ul class="contact-list">
						<li>
							<span class="c-icon">📍</span>
							<div class="c-info">
								<strong>Sede Central</strong>
								<span>San Fernando del Valle de Catamarca</span>
							</div>
						</li>
						<li>
							<span class="c-icon">📞</span>
							<div class="c-info">
								<strong>Teléfono</strong>
								<span>+54 383 445-1234</span>
							</div>
						</li>
						<li>
							<span class="c-icon">✉️</span>
							<div class="c-info">
								<strong>Email</strong>
								<span>secretaria@cpccatamarca.org.ar</span>
							</div>
						</li>
					</ul>
				</div>

				<div class="footer-map-box">
					<h4>Ubicación</h4>
					<div class="map-wrapper glass">
						<div class="map-marker">📍</div>
						<p>Capital, Catamarca</p>
						<div class="map-overlay">
							<span>Ver Mapa de Google</span>
						</div>
					</div>
				</div>

				<div class="footer-bottom">
					<div class="f-bottom-content">
						<p>&copy; {new Date().getFullYear()} CPC CTM. Todos los derechos reservados.</p>
						<div class="f-legal">
							<a href="#">Privacidad</a>
							<a href="#">Términos</a>
						</div>
					</div>
				</div>
			</div>
		</footer>

		<ContactDrawer />

		<style is:global>
			:root {
				--primary: #1b5e20; /* Deep Institutional Green */
				--primary-hover: #2e7d32;
				--primary-light: #e8f5e9;
				--primary-soft: rgba(27, 94, 32, 0.05);
				
				--accent: #2c3e50; /* Slate Grey for contrast */
				
				--gray-50: #fafafa;
				--gray-100: #f5f5f5;
				--gray-200: #eeeeee;
				--gray-300: #e0e0e0;
				--gray-700: #616161;
				--gray-800: #424242;
				--gray-900: #212121;
				
				--text-main: #1a1a1a;
				--text-light: #616161;
				--white: #ffffff;
				
				--shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
				--shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
				--shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
				
				--radius-md: 12px;
				--radius-lg: 16px;
				--transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.glass {
				background: rgba(255, 255, 255, 0.7);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.3);
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html {
				font-family: 'Inter', system-ui, sans-serif;
				background: var(--gray-50);
				color: var(--text-main);
				scroll-behavior: smooth;
			}

			body {
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				background: linear-gradient(135deg, #fcfcfc 0%, #f5f7fa 25%, #e2e8f0 50%, #f5f7fa 75%, #fcfcfc 100%);
				background-size: 200% 200%;
				animation: professionalShimmer 20s ease-in-out infinite;
				position: relative;
				background-attachment: fixed;
			}

			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.6) 0%, transparent 80%);
				pointer-events: none;
				z-index: -1;
				opacity: 0.3;
			}

			@keyframes professionalShimmer {
				0% { background-position: 0% 0%; }
				50% { background-position: 100% 100%; }
				100% { background-position: 0% 0%; }
			}

			.container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			h1, h2, h3, h4 {
				font-family: 'Outfit', sans-serif;
				color: var(--primary);
				font-weight: 700;
				line-height: 1.2;
			}

			/* Header */
			.main-header {
				background: var(--white);
				border-bottom: 2px solid #2E7D32; /* Verde Institucional */
				padding: 0.75rem 0;
				position: sticky;
				top: 0;
				z-index: 1000;
				box-shadow: var(--shadow-sm);
			}

			.header-content {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.header-left {
				display: flex;
				align-items: center;
				gap: 1.5rem;
			}

			.back-btn {
				background: var(--gray-100);
				border: 1px solid var(--gray-300);
				padding: 0.5rem 1rem;
				border-radius: var(--radius-md);
				font-weight: 600;
				cursor: pointer;
				display: flex;
				align-items: center;
				gap: 0.5rem;
				color: var(--text-main);
				transition: var(--transition);
				font-family: 'Inter', sans-serif;
				font-size: 0.9rem;
			}

			.back-btn:hover {
				background: var(--primary-light);
				border-color: var(--primary);
				color: var(--primary);
				transform: translateX(-3px);
			}

			.logo {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
			}

			.logo-icon {
				font-size: 2rem;
			}

			.logo-img {
				height: 50px;
				width: auto;
				object-fit: contain;
			}

			.logo-text {
				display: flex;
				flex-direction: column;
			}

			.brand {
				font-family: 'Outfit', sans-serif;
				font-weight: 700;
				font-size: 1.1rem;
				color: var(--primary);
				line-height: 1.2;
				max-width: 300px;
			}

			.sub-brand {
				font-size: 0.8rem;
				text-transform: uppercase;
				color: var(--text-light);
				font-weight: 600;
				letter-spacing: 0.05em;
			}

			.main-nav ul {
				list-style: none;
				display: flex;
				gap: 1.5rem;
				align-items: center;
			}

			.main-nav a, .contact-trigger {
				text-decoration: none;
				color: var(--text-main);
				font-weight: 600;
				font-size: 0.95rem;
				transition: var(--transition);
				background: none;
				border: none;
				cursor: pointer;
				font-family: inherit;
				padding: 0.5rem 0.75rem;
				border-radius: var(--radius-md);
			}

			.main-nav a:hover {
				color: var(--primary);
				background: var(--primary-soft);
			}

			.contact-trigger {
				background: var(--primary);
				color: white !important;
				padding: 0.6rem 1.2rem;
				box-shadow: var(--shadow-sm);
			}

			.contact-trigger:hover {
				background: var(--primary-hover);
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
			}

			/* Main Content */
			main {
				flex: 1;
				background-color: transparent;
				padding-bottom: 4rem;
			}

			/* Footer Renovado */
			.main-footer {
				background: var(--gray-900);
				color: white;
				padding: 5rem 0 2rem;
				margin-top: auto;
			}

			.footer-grid {
				display: grid;
				grid-template-columns: 2fr 1.5fr 1.5fr;
				gap: 4rem;
			}

			.footer-brand .f-logo {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1.5rem;
			}

			.f-icon { font-size: 2.25rem; }
			.f-text h3 { color: white; margin: 0; font-size: 1.5rem; }
			.f-text span { font-size: 0.8rem; text-transform: uppercase; color: var(--primary-hover); font-weight: 700; }
			.f-desc { font-size: 0.95rem; color: rgba(255,255,255,0.6); line-height: 1.6; max-width: 400px; }

			.footer-contact h4, .footer-map-box h4 {
				color: white;
				font-size: 1.1rem;
				margin-bottom: 2rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
			}

			.contact-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
			.contact-list li { display: flex; gap: 1rem; align-items: flex-start; }
			.c-icon { font-size: 1.25rem; opacity: 0.8; }
			.c-info strong { display: block; font-size: 0.9rem; color: var(--primary-hover); margin-bottom: 0.2rem; }
			.c-info span { font-size: 0.85rem; color: rgba(255,255,255,0.7); }

			.map-wrapper {
				height: 180px;
				border-radius: 16px;
				background: rgba(255,255,255,0.05);
				border: 1px solid rgba(255,255,255,0.1);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				position: relative;
				overflow: hidden;
				cursor: pointer;
				transition: var(--transition);
			}

			.map-wrapper:hover { background: rgba(255,255,255,0.1); border-color: var(--primary); }
			.map-marker { font-size: 2rem; margin-bottom: 0.5rem; }
			.map-wrapper p { font-size: 0.85rem; font-weight: 600; }
			
			.map-overlay {
				position: absolute;
				bottom: 0;
				left: 0;
				width: 100%;
				padding: 0.75rem;
				background: var(--primary);
				text-align: center;
				transform: translateY(100%);
				transition: var(--transition);
			}

			.map-wrapper:hover .map-overlay { transform: translateY(0); }
			.map-overlay span { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; }

			.footer-bottom {
				grid-column: 1 / -1;
				margin-top: 4rem;
				padding-top: 2rem;
				border-top: 1px solid rgba(255,255,255,0.1);
			}

			.f-bottom-content {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.f-bottom-content p { font-size: 0.85rem; color: rgba(255,255,255,0.4); }
			.f-legal { display: flex; gap: 2rem; }
			.f-legal a { text-decoration: none; color: rgba(255,255,255,0.4); font-size: 0.85rem; }
			.f-legal a:hover { color: var(--white); }

			@media (max-width: 1024px) {
				.footer-grid { grid-template-columns: 1fr; gap: 3rem; }
				.f-bottom-content { flex-direction: column; gap: 1.5rem; text-align: center; }
			}

			@media (max-width: 768px) {
				.header-content {
					flex-direction: column;
					padding-bottom: 1rem;
					gap: 1rem;
				}
				.brand {
					font-size: 0.9rem;
					text-align: center;
				}
				.sub-brand {
					text-align: center;
				}
				.logo {
					flex-direction: column;
					text-align: center;
				}
				.main-nav ul {
					gap: 0.5rem;
				}
			}
		</style>
	</body>
</html>
